## Common Commands

```bash
# Cluster
./scripts/k3d-manager create_cluster [name] [http_port] [https_port]
./scripts/k3d-manager deploy_cluster
CLUSTER_PROVIDER=k3s ./scripts/k3d-manager deploy_cluster -f
./scripts/k3d-manager destroy_cluster

# Services
./scripts/k3d-manager deploy_eso
./scripts/k3d-manager deploy_vault
./scripts/k3d-manager deploy_ldap
./scripts/k3d-manager deploy_ad           # Deploy OpenLDAP with AD schema (local AD testing)
./scripts/k3d-manager deploy_jenkins --enable-vault
./scripts/k3d-manager deploy_jenkins --enable-ldap --enable-vault
./scripts/k3d-manager deploy_jenkins --enable-ad --enable-vault
AD_DOMAIN=corp.example.com ./scripts/k3d-manager deploy_jenkins --enable-ad-prod --enable-vault

# Jenkins deployment modes – working vs broken
# WORKING:  deploy_jenkins --enable-vault
# WORKING:  deploy_jenkins --enable-vault --enable-ldap
# WORKING:  deploy_jenkins --enable-vault --enable-ad
# BROKEN:   deploy_jenkins (no vault) – policy creation always runs; jenkins-admin secret missing
# BROKEN:   deploy_jenkins --enable-ldap (without --enable-vault) – LDAP requires Vault for secrets

# Tests
./scripts/k3d-manager test all
./scripts/k3d-manager test core
./scripts/k3d-manager test install_k3d --case "test case name"

# Smoke test (manual – bin/smoke-test-jenkins.sh, Phases 1-3 complete)
./bin/smoke-test-jenkins.sh               # SSL + auth smoke tests against live Jenkins

# Debug
ENABLE_TRACE=1 ./scripts/k3d-manager <command>
DEBUG=1 ./scripts/k3d-manager <command>
```

