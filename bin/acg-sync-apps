#!/usr/bin/env bash
# bin/acg-sync-apps
#
# Trigger ArgoCD sync for data-layer, then show all remote pod status.
# Handles argocd-server port-forward and login automatically.
#
# Usage:
#   bin/acg-sync-apps
#
# Environment:
#   INFRA_CONTEXT  kubectl context for infra cluster (default: k3d-k3d-cluster)
#   APP_CONTEXT    kubectl context for app cluster   (default: ubuntu-k3s)
#   ARGOCD_NS      ArgoCD namespace                  (default: cicd)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
source "${REPO_ROOT}/scripts/lib/system.sh"

INFRA_CONTEXT="${INFRA_CONTEXT:-k3d-k3d-cluster}"
APP_CONTEXT="${APP_CONTEXT:-ubuntu-k3s}"
ARGOCD_NS="${ARGOCD_NS:-cicd}"
ARGOCD_APP="${ARGOCD_APP:-data-layer}"

SYNC_APPS_STATE_DIR="${SYNC_APPS_STATE_DIR:-${REPO_ROOT}/scratch/.state/acg-sync-apps}"
SYNC_APPS_LOG_DIR="${SYNC_APPS_LOG_DIR:-${REPO_ROOT}/scratch/logs}"
SYNC_APPS_PF_STATE_FILE="${SYNC_APPS_STATE_DIR}/acg-sync-apps-argocd-pf.env"

mkdir -p "${SYNC_APPS_STATE_DIR}" "${SYNC_APPS_LOG_DIR}"

SYNC_APPS_PF_LOG_FILE="$(mktemp "${SYNC_APPS_LOG_DIR}/acg-sync-apps-argocd-pf.XXXXXX.log" 2>/dev/null || printf '%s\n' "${SYNC_APPS_LOG_DIR}/acg-sync-apps-argocd-pf.log")"

_pf_pid=""
_pf_owned=0
_pf_log="${SYNC_APPS_PF_LOG_FILE}"

function _sync_apps_port_in_use() {
  local pf_port="$1"

  if command -v lsof >/dev/null 2>&1; then
    lsof -nP -iTCP:"${pf_port}" -sTCP:LISTEN >/dev/null 2>&1
    return $?
  fi

  if command -v nc >/dev/null 2>&1; then
    nc -z 127.0.0.1 "${pf_port}" >/dev/null 2>&1
    return $?
  fi

  return 1
}

function _sync_apps_listener_pids() {
  local pf_port="$1"

  if command -v lsof >/dev/null 2>&1; then
    lsof -nP -iTCP:"${pf_port}" -sTCP:LISTEN -t 2>/dev/null | sort -u
  fi
}

function _sync_apps_load_port_forward_state() {
  if [[ -r "${SYNC_APPS_PF_STATE_FILE}" ]]; then
    # shellcheck disable=SC1090
    source "${SYNC_APPS_PF_STATE_FILE}"
  fi
}

function _sync_apps_state_matches() {
  [[ "${SYNC_APPS_PF_CONTEXT:-}" == "${INFRA_CONTEXT}" ]] &&
    [[ "${SYNC_APPS_PF_NS:-}" == "${ARGOCD_NS}" ]] &&
    [[ "${SYNC_APPS_PF_PORT:-}" == "8080" ]] &&
    [[ "${SYNC_APPS_PF_SERVICE:-}" == "svc/argocd-server" ]]
}

function _sync_apps_write_port_forward_state() {
  mkdir -p "${SYNC_APPS_STATE_DIR}"
  cat >"${SYNC_APPS_PF_STATE_FILE}" <<EOF
SYNC_APPS_PF_PID=${_pf_pid}
SYNC_APPS_PF_CONTEXT=${INFRA_CONTEXT}
SYNC_APPS_PF_NS=${ARGOCD_NS}
SYNC_APPS_PF_PORT=8080
SYNC_APPS_PF_SERVICE=svc/argocd-server
SYNC_APPS_PF_LOG=${_pf_log}
EOF
}

function _sync_apps_clear_port_forward_state() {
  rm -f "${SYNC_APPS_PF_STATE_FILE}" 2>/dev/null || true
}

function _sync_apps_reconcile_port_forward() {
  local pf_port="$1"

  if ! _sync_apps_port_in_use "${pf_port}"; then
    return 1
  fi

  _sync_apps_load_port_forward_state
  if _sync_apps_state_matches &&
     [[ -n "${SYNC_APPS_PF_PID:-}" ]] &&
     kill -0 "${SYNC_APPS_PF_PID}" 2>/dev/null; then
    _pf_pid="${SYNC_APPS_PF_PID}"
    _pf_log="${SYNC_APPS_PF_LOG:-${_pf_log}}"
    if curl -sk --max-time 1 https://localhost:"${pf_port}"/ >/dev/null 2>&1; then
      _pf_owned=0
      _info "[sync-apps] Reusing existing argocd-server port-forward on ${pf_port}"
      return 0
    fi

    _warn "[sync-apps] Managed argocd-server port-forward is not ready yet — restarting it"
  else
    _warn "[sync-apps] Local port ${pf_port} is already in use by an unmanaged listener — stopping it"
  fi

  mapfile -t _existing_pids < <(_sync_apps_listener_pids "${pf_port}")
  if ((${#_existing_pids[@]})); then
    kill "${_existing_pids[@]}" 2>/dev/null || true
    for _i in $(seq 1 5); do
      if ! _sync_apps_port_in_use "${pf_port}"; then
        break
      fi
      sleep 1
    done
  fi

  _sync_apps_clear_port_forward_state
  return 1
}

_cleanup() {
  if [[ "${_pf_owned}" -eq 1 && -n "${_pf_pid}" ]]; then
    kill "${_pf_pid}" 2>/dev/null || true
  fi
  if [[ "${_pf_owned}" -eq 1 ]]; then
    _sync_apps_clear_port_forward_state
  fi
}
trap _cleanup EXIT

if ! _sync_apps_reconcile_port_forward 8080; then
  _info "[sync-apps] Starting argocd-server port-forward..."
  kubectl port-forward svc/argocd-server -n "${ARGOCD_NS}" 8080:443 \
    --context "${INFRA_CONTEXT}" >"${_pf_log}" 2>&1 &
  _pf_pid=$!
  _pf_owned=1
  _sync_apps_write_port_forward_state
  _pf_ready=0
  _pf_failed=0
  for _i in $(seq 1 15); do
    if curl -sk --max-time 1 https://localhost:8080/ >/dev/null 2>&1; then
      _pf_ready=1
      break
    fi
    if ! kill -0 "${_pf_pid}" 2>/dev/null; then
      _pf_failed=1
      break
    fi
    sleep 1
  done
  if [[ "${_pf_ready}" -eq 0 ]]; then
    if [[ "${_pf_failed}" -eq 1 ]]; then
      _info "[sync-apps] ERROR: argocd-server port-forward exited early — see ${_pf_log}"
    else
      _info "[sync-apps] ERROR: argocd-server port-forward not ready after 15s — see ${_pf_log}"
    fi
    tail -n 20 "${_pf_log}" 2>/dev/null || true
    exit 1
  fi
fi

_argocd_pass=$(kubectl get secret argocd-initial-admin-secret \
  -n "${ARGOCD_NS}" --context "${INFRA_CONTEXT}" \
  -o jsonpath='{.data.password}' | base64 -d)

_info "[sync-apps] Logging in to ArgoCD..."
argocd login localhost:8080 --username admin --password "${_argocd_pass}" \
  --plaintext --skip-test-tls --insecure --grpc-web </dev/null >/dev/null

if ! argocd app get "${ARGOCD_APP}" >/dev/null 2>&1; then
  _info "[sync-apps] ERROR: ArgoCD app '${ARGOCD_APP}' not found — is bootstrap complete?"
  _info "[sync-apps] Available apps (set ARGOCD_APP=<name> to target a different one):"
  argocd app list --output name 2>/dev/null || true
  exit 1
fi

_info "[sync-apps] Terminating any in-progress operation on ${ARGOCD_APP}..."
argocd app terminate-op "${ARGOCD_APP}" 2>/dev/null || true

_info "[sync-apps] Waiting for operation to clear..."
for _i in $(seq 1 20); do
  _phase=$(argocd app get "${ARGOCD_APP}" --output json 2>/dev/null \
    | grep -o '"phase":"[^"]*"' | head -1 | grep -o '[^"]*$' || echo "none")
  if [[ "$_phase" == "none" || "$_phase" == "Succeeded" || \
        "$_phase" == "Failed"  || "$_phase" == "Error" ]]; then
    break
  fi
  _info "[sync-apps] Operation still ${_phase}, waiting... (${_i}/20)"
  sleep 3
done

_info "[sync-apps] Syncing ${ARGOCD_APP} (async)..."
argocd app sync "${ARGOCD_APP}" --async

_info "[sync-apps] Pod status (${APP_CONTEXT}):"
kubectl get pods -A --context "${APP_CONTEXT}"
