#!/usr/bin/env bash
# bin/acg-sync-apps
#
# Trigger ArgoCD sync for data-layer, then show all remote pod status.
# Handles argocd-server port-forward and login automatically.
#
# Usage:
#   bin/acg-sync-apps
#
# Environment:
#   INFRA_CONTEXT  kubectl context for infra cluster (default: k3d-k3d-cluster)
#   APP_CONTEXT    kubectl context for app cluster   (default: ubuntu-k3s)
#   ARGOCD_NS      ArgoCD namespace                  (default: cicd)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
source "${REPO_ROOT}/scripts/lib/system.sh"

INFRA_CONTEXT="${INFRA_CONTEXT:-k3d-k3d-cluster}"
APP_CONTEXT="${APP_CONTEXT:-ubuntu-k3s}"
ARGOCD_NS="${ARGOCD_NS:-cicd}"
ARGOCD_APP="${ARGOCD_APP:-data-layer}"

_pf_pid=""
_pf_log="$(mktemp -t acg-sync-apps-argocd-pf.XXXXXX.log 2>/dev/null || printf '%s\n' "${TMPDIR:-/tmp}/acg-sync-apps-argocd-pf.log")"

_cleanup() {
  if [[ -n "${_pf_pid}" ]]; then
    kill "${_pf_pid}" 2>/dev/null || true
  fi
  if [[ -n "${_pf_log}" ]]; then
    rm -f "${_pf_log}" 2>/dev/null || true
  fi
}
trap _cleanup EXIT

_info "[sync-apps] Starting argocd-server port-forward..."
kubectl port-forward svc/argocd-server -n "${ARGOCD_NS}" 8080:443 \
  --context "${INFRA_CONTEXT}" >"${_pf_log}" 2>&1 &
_pf_pid=$!
_pf_ready=0
_pf_failed=0
for _i in $(seq 1 15); do
  if curl -sk --max-time 1 https://localhost:8080/ >/dev/null 2>&1; then
    _pf_ready=1
    break
  fi
  if ! kill -0 "${_pf_pid}" 2>/dev/null; then
    _pf_failed=1
    break
  fi
  sleep 1
done
if [[ "${_pf_ready}" -eq 0 ]]; then
  if [[ "${_pf_failed}" -eq 1 ]]; then
    _info "[sync-apps] ERROR: argocd-server port-forward exited early — see ${_pf_log}"
  else
    _info "[sync-apps] ERROR: argocd-server port-forward not ready after 15s — see ${_pf_log}"
  fi
  tail -n 20 "${_pf_log}" 2>/dev/null || true
  exit 1
fi

_argocd_pass=$(kubectl get secret argocd-initial-admin-secret \
  -n "${ARGOCD_NS}" --context "${INFRA_CONTEXT}" \
  -o jsonpath='{.data.password}' | base64 -d)

_info "[sync-apps] Logging in to ArgoCD..."
argocd login localhost:8080 --username admin --password "${_argocd_pass}" --insecure >/dev/null

if ! argocd app get "${ARGOCD_APP}" >/dev/null 2>&1; then
  _info "[sync-apps] ERROR: ArgoCD app '${ARGOCD_APP}' not found — is bootstrap complete?"
  _info "[sync-apps] Available apps (set ARGOCD_APP=<name> to target a different one):"
  argocd app list --output name 2>/dev/null || true
  exit 1
fi

_info "[sync-apps] Terminating any in-progress operation on ${ARGOCD_APP}..."
argocd app terminate-op "${ARGOCD_APP}" 2>/dev/null || true

_info "[sync-apps] Waiting for operation to clear..."
for _i in $(seq 1 20); do
  _phase=$(argocd app get "${ARGOCD_APP}" --output json 2>/dev/null \
    | grep -o '"phase":"[^"]*"' | head -1 | grep -o '[^"]*$' || echo "none")
  if [[ "$_phase" == "none" || "$_phase" == "Succeeded" || \
        "$_phase" == "Failed"  || "$_phase" == "Error" ]]; then
    break
  fi
  _info "[sync-apps] Operation still ${_phase}, waiting... (${_i}/20)"
  sleep 3
done

_info "[sync-apps] Syncing ${ARGOCD_APP} (async)..."
argocd app sync "${ARGOCD_APP}" --async

_info "[sync-apps] Pod status (${APP_CONTEXT}):"
kubectl get pods -A --context "${APP_CONTEXT}"
