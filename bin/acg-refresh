#!/usr/bin/env bash
# bin/acg-refresh
#
# Daily driver — refresh AWS credentials and restart the SSH tunnel.
# Use this when the ACG sandbox is already provisioned but creds expired.
#
# Usage:
#   bin/acg-refresh [sandbox-url]
#
# Environment:
#   ACG_SANDBOX_URL   Override default sandbox listing URL
#   PLURALSIGHT_EMAIL Pre-fill email on Pluralsight sign-in page

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "${REPO_ROOT}/scripts/lib/system.sh"
source "${REPO_ROOT}/scripts/lib/core.sh"
source "${REPO_ROOT}/scripts/plugins/gemini.sh"
source "${REPO_ROOT}/scripts/plugins/aws.sh"
source "${REPO_ROOT}/scripts/plugins/acg.sh"
source "${REPO_ROOT}/scripts/plugins/tunnel.sh"

login_prompt=0
sandbox_url=""
for arg in "$@"; do
  case "$arg" in
    --login-prompt)    login_prompt=1 ;;
    --no-login-prompt) login_prompt=0 ;;
    *)                 sandbox_url="$arg" ;;
  esac
done
sandbox_url="${sandbox_url:-${ACG_SANDBOX_URL:-}}"

if _is_mac; then
  _info "[acg-refresh] Pre-authorizing sudo for macOS host operations (launchd tunnel restart)..."
  sudo -v
fi

if [[ "$login_prompt" -eq 1 ]]; then
  _acg_sandbox_url="${sandbox_url:-https://app.pluralsight.com/hands-on/playground/cloud-sandboxes}"
  echo ""
  echo "=========================================================="
  echo "  ACTION REQUIRED: Confirm Pluralsight session is active"
  echo "=========================================================="
  echo ""
  echo "  If your Pluralsight session has expired, sign in first:"
  echo "     ${_acg_sandbox_url}"
  echo ""
  read -r -p "Press Enter once you are signed in to Pluralsight... "
  echo ""
fi

_info "[acg-refresh] Checking AWS credentials..."
if _acg_check_credentials 2>/dev/null; then
  _info "[acg-refresh] Credentials still valid — skipping extraction"
else
  _info "[acg-refresh] Credentials expired — extracting..."
  acg_get_credentials ${sandbox_url:+"$sandbox_url"}
fi

_info "[acg-refresh] Restarting tunnel..."
tunnel_stop 2>/dev/null || true
tunnel_start

if _is_mac; then
  _cloudflare_plist="/Library/LaunchDaemons/com.k3d-manager.cloudflare-tunnel.plist"
  if [[ -f "${_cloudflare_plist}" ]]; then
    _info "[acg-refresh] Restarting Cloudflare tunnel..."
    _run_command --interactive-sudo --quiet --soft -- launchctl bootout system "${_cloudflare_plist}" || true
    _run_command --interactive-sudo --quiet -- launchctl bootstrap system "${_cloudflare_plist}" \
      && _info "[acg-refresh] Cloudflare tunnel restarted" \
      || _warn "[acg-refresh] Cloudflare tunnel restart failed — run: sudo launchctl bootstrap system ${_cloudflare_plist}"
  fi
fi

_info "[acg-refresh] Done. Cluster should be reachable."
kubectl get nodes --context ubuntu-k3s
