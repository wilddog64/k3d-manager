#!/usr/bin/env bash
# bin/cluster-status
#
# One-shot cluster status — nodes, pods, ArgoCD apps, tunnel health.
# Read-only. Safe to run at any time.
#
# Usage:
#   bin/cluster-status
#
# Environment:
#   APP_CONTEXT    kubectl context for app cluster (auto-resolved if unset)
#   INFRA_CONTEXT  kubectl context for infra cluster (default: k3d-k3d-cluster)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
source "${REPO_ROOT}/scripts/lib/system.sh"
source "${REPO_ROOT}/scripts/lib/provider.sh"

CLUSTER_PROVIDER="$(_acg_resolve_provider)"
APP_CONTEXT="${APP_CONTEXT:-$(_acg_provider_context "${CLUSTER_PROVIDER}")}"
INFRA_CONTEXT="${INFRA_CONTEXT:-k3d-k3d-cluster}"
ARGOCD_NAMESPACE="${ARGOCD_NAMESPACE:-cicd}"

echo "=== Hub Cluster (${INFRA_CONTEXT}) ==="
kubectl get nodes --context "${INFRA_CONTEXT}" 2>/dev/null \
  || echo "Cannot reach Hub cluster"

echo ""
echo "=== Hub Pods — all namespaces (${INFRA_CONTEXT}) ==="
kubectl get pods -A --context "${INFRA_CONTEXT}" 2>/dev/null \
  || echo "Cannot reach Hub cluster"

case "${CLUSTER_PROVIDER}" in
  k3s-aws|k3s-gcp|k3s-az)
    echo ""
    echo "=== Tunnel ==="
    if curl -sf --max-time 3 http://localhost:6443 >/dev/null 2>&1; then
      echo "SSH tunnel: UP (port 6443 reachable)"
    else
      echo "SSH tunnel: DOWN (port 6443 not reachable)"
    fi
    ;;
esac

echo ""
echo "=== Nodes (${APP_CONTEXT}) ==="
kubectl get nodes --context "${APP_CONTEXT}" 2>/dev/null \
  || echo "Cannot reach app cluster — run bin/cluster-refresh"

echo ""
echo "=== Pods — all namespaces (${APP_CONTEXT}) ==="
kubectl get pods -A --context "${APP_CONTEXT}" 2>/dev/null \
  || echo "Cannot reach app cluster"

echo ""
echo "=== API Health (${APP_CONTEXT}) ==="
if kubectl get --raw='/healthz' --context "${APP_CONTEXT}" >/dev/null 2>&1; then
  echo "API server: UP (/healthz ok)"
else
  echo "API server: DOWN (/healthz unreachable)"
fi

echo ""
echo "=== App Observability (${APP_CONTEXT}) ==="
_prom_cr="acg-kube-prometheus-stack-prometheus"
_prom_available="$(kubectl --context "${APP_CONTEXT}" -n monitoring \
  get prometheus "${_prom_cr}" -o jsonpath='{.status.availableReplicas}/{.spec.replicas}' 2>/dev/null || true)"
if [[ -z "${_prom_available}" || "${_prom_available}" == "/" ]]; then
  echo "Prometheus: not installed (no ${_prom_cr} resource in monitoring)"
else
  echo "Prometheus: ${_prom_available} available"
  _prom_pod="$(kubectl --context "${APP_CONTEXT}" -n monitoring \
    get pods -l "operator.prometheus.io/name=${_prom_cr}" \
    -o jsonpath='{.items[0].metadata.name}' 2>/dev/null || true)"
  if [[ -n "${_prom_pod}" ]]; then
    _prom_restarts="$(kubectl --context "${APP_CONTEXT}" -n monitoring \
      get pod "${_prom_pod}" \
      -o jsonpath='{.status.containerStatuses[?(@.name=="prometheus")].restartCount}' 2>/dev/null || true)"
    _prom_reason="$(kubectl --context "${APP_CONTEXT}" -n monitoring \
      get pod "${_prom_pod}" \
      -o jsonpath='{.status.containerStatuses[?(@.name=="prometheus")].lastState.terminated.reason}' 2>/dev/null || true)"
    _prom_mem_limit="$(kubectl --context "${APP_CONTEXT}" -n monitoring \
      get statefulset prometheus-acg-kube-prometheus-stack-prometheus \
      -o jsonpath='{.spec.template.spec.containers[?(@.name=="prometheus")].resources.limits.memory}' 2>/dev/null || true)"
    if [[ "${_prom_reason}" == "OOMKilled" ]]; then
      echo "WARN Prometheus backend unhealthy: ${_prom_pod} last terminated OOMKilled; restarts=${_prom_restarts:-0}; memory limit=${_prom_mem_limit:-unknown}"
      echo "WARN Grafana panels may be blank until Prometheus stays ready"
    elif [[ "${_prom_available}" != "1/1" ]]; then
      echo "WARN Prometheus backend unhealthy: ${_prom_pod} not fully ready; restarts=${_prom_restarts:-0}; last termination=${_prom_reason:-unknown}"
      echo "WARN Grafana panels may be blank until Prometheus stays ready"
    fi
  fi
fi

echo ""
echo "=== Hub ArgoCD Registration (${INFRA_CONTEXT}, ns ${ARGOCD_NAMESPACE}) ==="
if kubectl get secret "cluster-${APP_CONTEXT}" -n "${ARGOCD_NAMESPACE}" \
     --context "${INFRA_CONTEXT}" >/dev/null 2>&1; then
  echo "Registered: secret cluster-${APP_CONTEXT} present"
else
  echo "NOT registered: secret cluster-${APP_CONTEXT} missing"
fi

echo ""
echo "=== ArgoCD Apps ==="
_apps_raw="$(kubectl get applications.argoproj.io -A --context "${INFRA_CONTEXT}" 2>/dev/null || true)"
if [[ -z "${_apps_raw}" ]]; then
  echo "Cannot reach Hub cluster or ArgoCD CRDs not installed"
else
  _apps_body="$(printf '%s\n' "${_apps_raw}" | sed '1d')"
  _core_apps="$(printf '%s\n' "${_apps_body}" | awk '$2 !~ /-preflight-/')"
  _preflight_apps="$(printf '%s\n' "${_apps_body}" | awk '$2 ~ /-preflight-/')"

  if [[ -n "${_core_apps}" ]]; then
    printf '%s\n' "${_apps_raw}" | awk 'NR==1 || $2 !~ /-preflight-/'
  else
    echo "(no core ArgoCD apps)"
  fi

  if [[ -n "${_preflight_apps}" ]]; then
    echo ""
    echo "=== ArgoCD Preflight Apps ==="
    echo "(shown separately so vCluster/preflight drift does not look like Hostinger app-cluster failure)"
    printf '%s\n' "${_apps_raw}" | awk 'NR==1 || $2 ~ /-preflight-/'
  fi
fi

echo ""
echo "=== ArgoCD ApplicationSets ==="
kubectl get applicationsets.argoproj.io -A --context "${INFRA_CONTEXT}" 2>/dev/null \
  || echo "Cannot reach Hub cluster or ArgoCD CRDs not installed"

echo ""
echo "=== ArgoCD Image Updater ==="
_iu_ready="$(kubectl get deploy argocd-image-updater -n "${ARGOCD_NAMESPACE}" \
  --context "${INFRA_CONTEXT}" -o jsonpath='{.status.readyReplicas}/{.status.replicas}' 2>/dev/null || true)"
if [[ -z "${_iu_ready}" || "${_iu_ready}" == "/" ]]; then
  echo "Not installed (no argocd-image-updater deployment in ${ARGOCD_NAMESPACE})"
else
  echo "Deployment: ${_iu_ready} ready"

  _iu_logs="$(kubectl logs deploy/argocd-image-updater -n "${ARGOCD_NAMESPACE}" \
    --context "${INFRA_CONTEXT}" --tail=200 2>/dev/null || true)"

  _iu_cycle="$(printf '%s\n' "${_iu_logs}" | grep -F 'Processing results:' | tail -1 \
    | sed 's/.*Processing results: //; s/"$//' || true)"
  if [[ -n "${_iu_cycle}" ]]; then
    echo "Last cycle: ${_iu_cycle}"
  else
    echo "Last cycle: (no completed cycle in recent logs)"
  fi

  _iu_updates="$(printf '%s\n' "${_iu_logs}" | grep -c 'images_updated=[1-9]' || true)"
  _iu_idle_cycle=0
  if [[ "${_iu_cycle}" == *"applications=0"* ]] && \
     [[ "${_iu_cycle}" == *"images_considered=0"* ]] && \
     [[ "${_iu_cycle}" == *"images_updated=0"* ]]; then
    _iu_idle_cycle=1
  fi
  if [[ "${_iu_updates}" -ge 3 ]] && [[ "${_iu_idle_cycle}" -eq 0 ]]; then
    echo "WARN Flapping: ${_iu_updates} recent cycles wrote an update — an app may not be converging"
  elif [[ "${_iu_updates}" -ge 3 ]] && [[ "${_iu_idle_cycle}" -eq 1 ]]; then
    echo "Note: historical update churn remains in recent logs, but the controller is currently idle"
  fi

  echo "Mode:"
  _iu_watch="$(kubectl get applications.argoproj.io -n "${ARGOCD_NAMESPACE}" \
    --context "${INFRA_CONTEXT}" --no-headers \
    -o custom-columns='N:.metadata.name,IL:.metadata.annotations.argocd-image-updater\.argoproj\.io/image-list' 2>/dev/null \
    | awk '$2 != "<none>" && $2 != "" { printf "  %s -> %s\n", $1, $2 }' || true)"
  if [[ -n "${_iu_watch}" ]]; then
    echo "  Annotation-driven enrollment active for the applications below"
    echo "Watching:"
    printf '%s\n' "${_iu_watch}"
  else
    echo "  CVE-gated promotion controller active; no applications are statically enrolled via image-list annotations"
  fi
fi

echo ""
echo "=== App CVE Scan ==="
_app_cve_cron="$(kubectl get cronjob app-cve-scan -n platform-ops \
  --context "${INFRA_CONTEXT}" \
  -o jsonpath='{.spec.schedule}|{.spec.suspend}|{.status.lastScheduleTime}' 2>/dev/null || true)"
if [[ -z "${_app_cve_cron}" ]]; then
  echo "Not installed (no app-cve-scan CronJob in platform-ops)"
else
  IFS='|' read -r _app_cve_schedule _app_cve_suspend _app_cve_last <<<"${_app_cve_cron}"
  echo "CronJob: schedule=${_app_cve_schedule:-unknown} suspend=${_app_cve_suspend:-unknown} lastSchedule=${_app_cve_last:-never}"

  _app_cve_job="$(kubectl get jobs -n platform-ops \
    --context "${INFRA_CONTEXT}" \
    -l batch.kubernetes.io/cronjob-name=app-cve-scan \
    --sort-by=.metadata.creationTimestamp \
    -o name 2>/dev/null | tail -1 || true)"
  if [[ -z "${_app_cve_job}" ]]; then
    echo "Last Job: none"
    echo "Last Result:"
    echo "  shopping-cart-basket: no result in latest run"
    echo "  shopping-cart-frontend: no result in latest run"
    echo "  shopping-cart-order: no result in latest run"
    echo "  shopping-cart-payment: no result in latest run"
    echo "  shopping-cart-product-catalog: no result in latest run"
  else
    _app_cve_job_name="${_app_cve_job#job.batch/}"
    _app_cve_job_state="$(kubectl get job "${_app_cve_job_name}" -n platform-ops \
      --context "${INFRA_CONTEXT}" \
      -o jsonpath='{.status.succeeded}|{.status.failed}|{.status.active}' 2>/dev/null || true)"
    IFS='|' read -r _app_cve_succeeded _app_cve_failed _app_cve_active <<<"${_app_cve_job_state}"
    _app_cve_status="unknown"
    if [[ "${_app_cve_succeeded:-0}" -ge 1 ]]; then
      _app_cve_status="success"
    elif [[ "${_app_cve_failed:-0}" -ge 1 ]]; then
      _app_cve_status="failed"
    elif [[ "${_app_cve_active:-0}" -ge 1 ]]; then
      _app_cve_status="running"
    fi
    echo "Last Job: ${_app_cve_job_name} ${_app_cve_status}"

    _app_cve_logs="$(kubectl logs -n platform-ops "${_app_cve_job}" \
      --context "${INFRA_CONTEXT}" --tail=200 2>/dev/null || true)"
    echo "Last Result:"
    for _svc in shopping-cart-basket shopping-cart-frontend shopping-cart-order shopping-cart-payment shopping-cart-product-catalog; do
      _app_cve_summary="no result in latest run"
      _promotion_line="$(printf '%s\n' "${_app_cve_logs}" | grep -F "PROMOTION ${_svc}:" | tail -1 || true)"
      if [[ -n "${_promotion_line}" ]]; then
        _app_cve_summary="$(printf '%s\n' "${_promotion_line}" | sed 's/.*PROMOTION [^:]*: /promoted /')"
      else
        _clean_line="$(printf '%s\n' "${_app_cve_logs}" | grep -F "STAGE ${_svc}: deployed image" | grep -F "has no HIGH/CRITICAL findings" | tail -1 || true)"
        _rebuild_line="$(printf '%s\n' "${_app_cve_logs}" | grep -F "STAGE ${_svc}: rebuild dispatched" | tail -1 || true)"
        _candidate_line="$(printf '%s\n' "${_app_cve_logs}" | grep -F "STAGE ${_svc}: failed to resolve immutable sha-* candidate" | tail -1 || true)"
        if [[ -n "${_clean_line}" ]]; then
          _app_cve_summary="clean"
        elif [[ -n "${_rebuild_line}" ]]; then
          _app_cve_summary="rebuild dispatched"
        elif [[ -n "${_candidate_line}" ]]; then
          _app_cve_summary="candidate missing"
        fi
      fi
      echo "  ${_svc}: ${_app_cve_summary}"
    done
  fi
fi

if [[ "${CLUSTER_PROVIDER}" == "k3s-aws" ]]; then
  echo ""
  echo "=== AWS Credentials ==="
  if aws sts get-caller-identity --output table 2>/dev/null; then
    : # printed inline
  else
    echo "AWS credentials invalid or expired — run bin/cluster-refresh"
  fi
fi

echo ""
echo "=== Service Health ==="
_ALERTMANAGER_HEALTH_URL="${K3DM_ALERTMANAGER_HEALTH_URL:-https://alertmanager.3ai-talk.org/api/v2/status}"
_alertmanager_code="$(curl -sk --max-time 3 -o /dev/null -w '%{http_code}' "${_ALERTMANAGER_HEALTH_URL}" 2>/dev/null || echo 000)"
if [[ "${_alertmanager_code}" == "200" ]]; then
  echo "  ✅ Alertmanager: HTTP 200"
else
  echo "  ❌ Alertmanager: HTTP ${_alertmanager_code} (${_ALERTMANAGER_HEALTH_URL})"
fi

_WEBHOOK_TOKEN="${K3DM_WEBHOOK_TOKEN:-$(security find-generic-password -s k3dm-webhook-token -w 2>/dev/null || true)}"
_WEBHOOK_PORT="${K3DM_WEBHOOK_PORT:-7443}"
if [[ -n "${_WEBHOOK_TOKEN}" ]]; then
  _health_json=$(curl -sf --max-time 90 \
    -H "Authorization: Bearer ${_WEBHOOK_TOKEN}" \
    "http://localhost:${_WEBHOOK_PORT}/api/v1/health?provider=${CLUSTER_PROVIDER}" 2>/dev/null || true)
  if [[ -n "${_health_json}" ]]; then
    echo "${_health_json}" | python3 -c "
import sys, json
data = json.load(sys.stdin)
for s in data.get('services', []):
    icon = '✅' if s['ok'] else '❌'
    print(f'  {icon} {s[\"name\"]}: {s[\"detail\"]}')
"
  else
    echo "  (webhook unreachable at localhost:${_WEBHOOK_PORT} — run: make restart-webhook)"
  fi
else
  echo "  (webhook token not in Keychain — set K3DM_WEBHOOK_TOKEN or run: make install-webhook)"
fi
