#!/usr/bin/env bash
# Query Keycloak SSO user passwords from Vault.
# Passwords are generated by acg-up (Step 10d.5) and rotate on every make up.
#
# Usage:
#   bin/get-keycloak-password              # show all users
#   bin/get-keycloak-password admin        # show one user
#   bin/get-keycloak-password admin -q     # password only (no labels)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
# shellcheck source=scripts/lib/system.sh
source "${REPO_ROOT}/scripts/lib/system.sh"

_VAULT_NS="secrets"
_USERS=(admin developer operator)
_TARGET=""
_QUIET=0

for _arg in "$@"; do
  case "${_arg}" in
    -q|--quiet) _QUIET=1 ;;
    -h|--help)
      cat <<'EOF'
Usage: bin/get-keycloak-password [USER] [-q]

  USER    One of: admin, developer, operator (default: all)
  -q      Print password only — no labels (useful for scripting)

Vault path: secret/keycloak/users/<user>
Passwords rotate on every make up.
EOF
      exit 0 ;;
    -*) _err "Unknown option: ${_arg}"; exit 1 ;;
    *)  _TARGET="${_arg}" ;;
  esac
done

if [[ -n "${_TARGET}" ]]; then
  _USERS=("${_TARGET}")
fi

_VAULT_TOKEN=$(kubectl get secret -n "${_VAULT_NS}" vault-root \
  -o jsonpath='{.data.root_token}' 2>/dev/null | base64 -d)
if [[ -z "${_VAULT_TOKEN}" ]]; then
  _err "Vault root token not found — is the cluster up?"
  exit 1
fi

_vault_get() {
  local _path="$1" _field="$2"
  kubectl exec -n "${_VAULT_NS}" vault-0 -- \
    env VAULT_TOKEN="${_VAULT_TOKEN}" vault kv get -field="${_field}" "${_path}" 2>/dev/null
}

for _user in "${_USERS[@]}"; do
  _path="secret/keycloak/users/${_user}"
  _pass=$(_vault_get "${_path}" "password" || true)
  if [[ -z "${_pass}" ]]; then
    _warn "${_user}: not found in Vault (run make up first)"
    continue
  fi
  if [[ ${_QUIET} -eq 1 ]]; then
    echo "${_pass}"
  else
    _info "${_user}: ${_pass}"
  fi
done
