#!/usr/bin/env bash
# Show OCI credentials stored in macOS keychain.
#
# Usage:
#   bin/show-oci-credentials              # show all (passphrase + private key)
#   bin/show-oci-credentials passphrase   # show passphrase only
#   bin/show-oci-credentials key          # show private key only
#   bin/show-oci-credentials -q           # values only, no labels

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
# shellcheck source=scripts/lib/system.sh
source "${REPO_ROOT}/scripts/lib/system.sh"

_TARGET="all"
_QUIET=0

for _arg in "$@"; do
  case "${_arg}" in
    -q|--quiet) _QUIET=1 ;;
    -h|--help)
      cat <<'EOF'
Usage: bin/show-oci-credentials [passphrase|key] [-q]

  passphrase   Show OCI API key passphrase only
  key          Show OCI private key PEM only
  (default)    Show both

  -q           Values only — no labels (useful for scripting)

Keychain items: oci-k3d-manager-passphrase, oci-k3d-manager-private-key
EOF
      exit 0 ;;
    -*) _err "Unknown option: ${_arg}"; exit 1 ;;
    passphrase|key) _TARGET="${_arg}" ;;
    *) _err "Unknown argument: ${_arg}"; exit 1 ;;
  esac
done

if ! command -v security >/dev/null 2>&1; then
  _err "macOS Keychain not available (security command missing)"
  exit 1
fi

_keychain_get() {
  local _service="$1"
  security find-generic-password -s "${_service}" -w 2>/dev/null || {
    _err "Not found in keychain: ${_service}"
    return 1
  }
}

_show_passphrase() {
  local _val
  _val=$(_keychain_get "oci-k3d-manager-passphrase")
  if [[ ${_QUIET} -eq 1 ]]; then
    echo "${_val}"
  else
    _info "OCI key passphrase: ${_val}"
  fi
}

_show_key() {
  local _val
  _val=$(_keychain_get "oci-k3d-manager-private-key")
  if [[ ${_QUIET} -eq 1 ]]; then
    echo "${_val}"
  else
    _info "OCI private key:"
    echo "${_val}"
  fi
}

case "${_TARGET}" in
  passphrase) _show_passphrase ;;
  key)        _show_key ;;
  all)        _show_passphrase; _show_key ;;
esac
