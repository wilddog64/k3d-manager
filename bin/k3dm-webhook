#!/usr/bin/env python3
"""k3dm-webhook — authenticated webhook server for k3d-manager laptop automation."""

import datetime
import hmac
import http.server
import json
import os
import re
import subprocess
import threading
import urllib.request
import uuid
from pathlib import Path

PORT = int(os.environ.get("K3DM_WEBHOOK_PORT", "7443"))
MAX_BODY = 4096
_JOB_ID_RE = re.compile(r'^[0-9a-f]{8}$')
REPO_ROOT = os.environ.get(
    "K3DM_REPO_ROOT",
    str(Path.home() / "src/gitrepo/personal/k3d-manager")
)
TOKEN_FILE = Path.home() / ".k3dm" / "webhook-token"
JOB_DIR = Path("/tmp/k3dm-webhook-jobs")
SLACK_WEBHOOK_URL = os.environ.get("K3DM_SLACK_WEBHOOK_URL", "")
ANTHROPIC_API_KEY = os.environ.get("ANTHROPIC_API_KEY", "")
ANALYSIS_MODEL = os.environ.get("K3DM_ANALYSIS_MODEL", "claude-haiku-4-5-20251001")


def _get_token():
    token = os.environ.get("K3DM_WEBHOOK_TOKEN")
    if token:
        return token
    try:
        r = subprocess.run(
            ["security", "find-generic-password",
             "-s", "k3dm-webhook-token", "-a", "k3dm", "-w"],
            capture_output=True, text=True
        )
        if r.returncode == 0 and r.stdout.strip():
            return r.stdout.strip()
    except Exception:
        pass
    if TOKEN_FILE.exists():
        return TOKEN_FILE.read_text().strip()
    return None


def _current_label(env, key="argocd-chart-version"):
    r = subprocess.run(
        ["kubectl", "get", "secrets", "-n", "cicd",
         "-l", f"argocd.argoproj.io/secret-type=cluster,environment={env}",
         "-o", f"jsonpath={{.items[0].metadata.labels.{key}}}"],
        capture_output=True, text=True
    )
    return r.stdout.strip()


def _secret_name(env):
    r = subprocess.run(
        ["kubectl", "get", "secrets", "-n", "cicd",
         "-l", f"argocd.argoproj.io/secret-type=cluster,environment={env}",
         "-o", "jsonpath={.items[0].metadata.name}"],
        capture_output=True, text=True
    )
    return r.stdout.strip()


def _patch_label(secret, version):
    patch = json.dumps({"metadata": {"labels": {"argocd-chart-version": version}}})
    subprocess.run(
        ["kubectl", "patch", "secret", secret, "-n", "cicd",
         "--type=merge", "-p", patch],
        check=True
    )


def _run_upgrade(job_id, chart_version, stage):
    job_dir = JOB_DIR / job_id
    lines = []

    def _log(msg):
        lines.append(msg + "\n")

    def _finish(status):
        (job_dir / "status").write_text(status)
        (job_dir / "output").write_text("".join(lines))

    try:
        (job_dir / "status").write_text("running")
        env_label = "dev" if stage == "acg" else "infra"

        # Idempotency check
        current = _current_label(env_label)
        if current == chart_version:
            _log(f"{stage}: already at {chart_version} — no-op")
            _finish("success")
            return

        if stage == "acg":
            _log("Running make up...")
            proc = subprocess.Popen(
                ["make", "up"],
                cwd=REPO_ROOT,
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                text=True
            )
            for line in proc.stdout:
                lines.append(line)
            proc.wait()
            if proc.returncode != 0:
                raise RuntimeError(f"make up exited {proc.returncode}")
            _log("make up complete")

        secret = _secret_name(env_label)
        if not secret:
            raise RuntimeError(f"No cluster secret found for environment={env_label}")

        _patch_label(secret, chart_version)
        _log(f"Patched {secret}: argocd-chart-version={chart_version}")
        _finish("success")

    except Exception as exc:
        _log(f"ERROR: {exc}")
        _finish("failed")


def _run_cluster(job_id, action, provider="aws"):
    job_dir = JOB_DIR / job_id
    lines = []
    _provider_map = {"aws": "k3s-aws", "gcp": "k3s-gcp", "azure": "k3s-azure"}
    _cluster_provider = _provider_map.get(provider, "k3s-aws")

    def _log(msg):
        lines.append(msg + "\n")

    def _finish(status):
        (job_dir / "status").write_text(status)
        (job_dir / "output").write_text("".join(lines))
        _ru_file = job_dir / "response_url"
        if _ru_file.exists():
            _ru = _ru_file.read_text().strip()
            if _ru:
                emoji = "✅" if status == "success" else "❌"
                _slack_post(_ru, f"{emoji} *{action}* ({provider}) — {status}\n```{''.join(lines)[-800:]}```")

    try:
        (job_dir / "status").write_text("running")
        if action == "up":
            cmd = ["make", "up", f"CLUSTER_PROVIDER={_cluster_provider}"]
        else:
            cmd = ["make", "down", "KEEP_LOCAL=1"]
        _log(f"Running {' '.join(cmd)}...")
        proc = subprocess.Popen(
            cmd,
            cwd=REPO_ROOT,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True
        )
        for line in proc.stdout:
            lines.append(line)
        proc.wait()
        if proc.returncode != 0:
            raise RuntimeError(f"{' '.join(cmd)} exited {proc.returncode}")
        _log(f"{action} complete")
        if action == "up":
            _record_acg_state(provider)
        _finish("success")
    except Exception as exc:
        _log(f"ERROR: {exc}")
        _finish("failed")


def _record_acg_state(provider):
    """Write provision timestamp to Hub platform-ops ConfigMap."""
    ts = str(int(datetime.datetime.utcnow().timestamp()))
    create = subprocess.run(
        ["kubectl", "create", "configmap", "acg-state",
         f"--from-literal=provisioned-at={ts}",
         f"--from-literal=provider={provider}",
         "-n", "platform-ops",
         "--dry-run=client", "-o", "yaml"],
        capture_output=True, text=True
    )
    if create.returncode == 0:
        subprocess.run(
            ["kubectl", "apply", "-f", "-"],
            input=create.stdout,
            capture_output=True
        )


def _slack_post(url, text):
    """POST a text message to a Slack incoming webhook or response_url."""
    if not url:
        return
    data = json.dumps({"text": text, "response_type": "in_channel"}).encode()
    req = urllib.request.Request(url, data=data,
                                 headers={"Content-Type": "application/json"})
    try:
        urllib.request.urlopen(req, timeout=10)
    except Exception:
        pass


def _call_claude(prompt):
    """Call Anthropic Messages API with stdlib urllib. Returns text or error string."""
    if not ANTHROPIC_API_KEY:
        return "ANTHROPIC_API_KEY not configured — skipping AI analysis"
    data = json.dumps({
        "model": ANALYSIS_MODEL,
        "max_tokens": 1024,
        "messages": [{"role": "user", "content": prompt}]
    }).encode()
    req = urllib.request.Request(
        "https://api.anthropic.com/v1/messages",
        data=data,
        headers={
            "x-api-key": ANTHROPIC_API_KEY,
            "anthropic-version": "2023-06-01",
            "content-type": "application/json"
        }
    )
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            result = json.loads(resp.read())
            return result["content"][0]["text"]
    except Exception as exc:
        return f"Claude API error: {exc}"


def _run_cluster_status(job_id, response_url):
    """Check ACG cluster reachability + ArgoCD app health; post result to response_url."""
    job_dir = JOB_DIR / job_id
    lines = []

    def _log(msg):
        lines.append(msg + "\n")

    def _finish(status):
        (job_dir / "status").write_text(status)
        (job_dir / "output").write_text("".join(lines))
        if response_url:
            _slack_post(response_url, "".join(lines))

    try:
        (job_dir / "status").write_text("running")

        nodes = subprocess.run(
            ["kubectl", "get", "nodes", "--context", "ubuntu-k3s",
             "--request-timeout=8s", "--no-headers"],
            capture_output=True, text=True
        )
        if nodes.returncode != 0:
            _log("❌ *ACG cluster unreachable* — sandbox may have expired.")
            _finish("success")
            return

        _log("✅ *ACG cluster nodes:*")
        _log(f"```{nodes.stdout.strip()}```")

        apps = subprocess.run(
            ["kubectl", "get", "applications", "-n", "cicd",
             "--context", "ubuntu-k3s",
             "--no-headers",
             "-o", "custom-columns=NAME:.metadata.name,SYNC:.status.sync.status,HEALTH:.status.health.status"],
            capture_output=True, text=True
        )
        if apps.returncode == 0 and apps.stdout.strip():
            _log("\n*ArgoCD apps:*")
            _log(f"```{apps.stdout.strip()}```")
        else:
            _log("\n_ArgoCD app status unavailable_")

        _finish("success")
    except Exception as exc:
        _log(f"ERROR: {exc}")
        _finish("failed")


def _run_analyze(job_id, alert_payload, response_url=""):
    """Gather kubectl diagnostics for firing alerts; call Claude; post to Slack."""
    job_dir = JOB_DIR / job_id
    lines = []

    def _log(msg):
        lines.append(msg + "\n")

    def _finish(status):
        (job_dir / "status").write_text(status)
        (job_dir / "output").write_text("".join(lines))

    try:
        (job_dir / "status").write_text("running")
        alerts = alert_payload.get("alerts", [])
        firing = [a for a in alerts if a.get("status") == "firing"]
        if not firing:
            _finish("success")
            return

        for alert in firing:
            app_name = alert.get("labels", {}).get("name", "")
            alert_name = alert.get("labels", {}).get("alertname", "unknown")
            _log(f"=== {alert_name}: {app_name} ===\n")

            diag_parts = []
            if app_name:
                desc = subprocess.run(
                    ["kubectl", "describe", "application", app_name, "-n", "cicd"],
                    capture_output=True, text=True
                )
                if desc.returncode == 0:
                    diag_parts.append(f"ArgoCD Application:\n{desc.stdout[-3000:]}")

            pods = subprocess.run(
                ["kubectl", "get", "pods", "-A",
                 "--field-selector=status.phase!=Running",
                 "--no-headers"],
                capture_output=True, text=True
            )
            if pods.returncode == 0 and pods.stdout.strip():
                diag_parts.append(f"Non-running pods:\n{pods.stdout.strip()}")

            if not diag_parts:
                _log("No diagnostics gathered\n")
                continue

            diagnostics = "\n\n".join(diag_parts)
            prompt = (
                f"You are a Kubernetes operations expert. Analyze this alert and give a "
                f"concise diagnosis (2-3 sentences) and the single most likely fix.\n\n"
                f"Alert: {alert_name} on app '{app_name}'\n\n"
                f"Diagnostics:\n{diagnostics}"
            )
            analysis = _call_claude(prompt)
            _log(analysis + "\n")

            notify_url = response_url or SLACK_WEBHOOK_URL
            if notify_url:
                _slack_post(notify_url,
                    f"🔍 *{alert_name}* — `{app_name}`\n{analysis}")

        _finish("success")
    except Exception as exc:
        _log(f"ERROR: {exc}")
        _finish("failed")


class _Handler(http.server.BaseHTTPRequestHandler):
    def _auth(self):
        token = _get_token()
        if not token:
            return False
        return hmac.compare_digest(
            self.headers.get("Authorization", ""),
            f"Bearer {token}"
        )

    def _json(self, code, body):
        data = json.dumps(body, separators=(",", ":")).encode()
        self.send_response(code)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(data)))
        self.end_headers()
        self.wfile.write(data)

    def do_POST(self):
        if not self._auth():
            self._json(401, {"error": "unauthorized"})
            return
        if self.path.startswith("/api/") and not self.path.startswith("/api/v1/"):
            self._json(400, {"error": "invalid api path"})
            return

        length = int(self.headers.get("Content-Length", 0))
        if length > MAX_BODY:
            self._json(413, {"error": "request too large"})
            return
        body = json.loads(self.rfile.read(length) or b"{}")
        if self.path == "/api/v1/argocd-upgrade":
            chart_version = body.get("chart_version", "")
            stage = body.get("stage", "")
            if not chart_version or stage not in ("acg", "infra"):
                self._json(400, {"error": "chart_version and stage (acg|infra) required"})
                return
            job_id = str(uuid.uuid4())[:8]
            (JOB_DIR / job_id).mkdir(parents=True, exist_ok=True)
            (JOB_DIR / job_id / "status").write_text("queued")
            threading.Thread(
                target=_run_upgrade,
                args=(job_id, chart_version, stage),
                daemon=True
            ).start()
            self._json(202, {"job_id": job_id, "status": "queued"})
            return

        if self.path == "/api/v1/cluster":
            action = body.get("action", "")
            if action not in ("up", "down"):
                self._json(400, {"error": "action (up|down) required"})
                return
            provider = body.get("provider", "aws")
            if provider not in ("aws", "gcp", "azure"):
                provider = "aws"
            response_url = body.get("response_url", "")
            job_id = str(uuid.uuid4())[:8]
            (JOB_DIR / job_id).mkdir(parents=True, exist_ok=True)
            (JOB_DIR / job_id / "status").write_text("queued")
            if response_url:
                (JOB_DIR / job_id / "response_url").write_text(response_url)
            threading.Thread(
                target=_run_cluster,
                args=(job_id, action, provider),
                daemon=True
            ).start()
            self._json(202, {"job_id": job_id, "status": "queued"})
            return

        if self.path == "/api/v1/cluster-status":
            response_url = body.get("response_url", "")
            job_id = str(uuid.uuid4())[:8]
            (JOB_DIR / job_id).mkdir(parents=True, exist_ok=True)
            (JOB_DIR / job_id / "status").write_text("queued")
            threading.Thread(
                target=_run_cluster_status,
                args=(job_id, response_url),
                daemon=True
            ).start()
            self._json(202, {"job_id": job_id, "status": "queued"})
            return

        if self.path == "/api/v1/analyze":
            response_url = body.get("response_url", "")
            job_id = str(uuid.uuid4())[:8]
            (JOB_DIR / job_id).mkdir(parents=True, exist_ok=True)
            (JOB_DIR / job_id / "status").write_text("queued")
            threading.Thread(
                target=_run_analyze,
                args=(job_id, body, response_url),
                daemon=True
            ).start()
            self._json(202, {"job_id": job_id, "status": "queued"})
            return

        self._json(404, {"error": "not found"})

    def do_GET(self):
        if not self._auth():
            self._json(401, {"error": "unauthorized"})
            return
        if self.path.startswith("/api/") and not self.path.startswith("/api/v1/"):
            self._json(400, {"error": "invalid api path"})
            return
        if not self.path.startswith("/api/v1/status/"):
            self._json(404, {"error": "not found"})
            return

        job_id = self.path.rsplit("/", 1)[-1]
        if not _JOB_ID_RE.match(job_id):
            self._json(400, {"error": "invalid job id"})
            return
        job_dir = JOB_DIR / job_id
        if not job_dir.exists():
            self._json(404, {"error": "job not found"})
            return

        status = (job_dir / "status").read_text().strip()
        output_file = job_dir / "output"
        output = output_file.read_text()[-2000:] if output_file.exists() else ""
        self._json(200, {"job_id": job_id, "status": status, "output": output})

    def log_message(self, *_):
        pass  # suppress access log noise


if __name__ == "__main__":
    JOB_DIR.mkdir(parents=True, exist_ok=True)
    server = http.server.ThreadingHTTPServer(("127.0.0.1", PORT), _Handler)
    print(f"[k3dm-webhook] listening on 127.0.0.1:{PORT}")
    server.serve_forever()
