#!/usr/bin/env python3
"""k3dm-webhook — authenticated webhook server for k3d-manager laptop automation."""

import datetime
import hmac
import http.server
import json
import os
import re
import signal
import subprocess
import threading
import urllib.request
import uuid
from pathlib import Path

PORT = int(os.environ.get("K3DM_WEBHOOK_PORT", "7443"))
MAX_BODY = 4096
_JOB_ID_RE = re.compile(r'^[0-9a-f]{8}$')
REPO_ROOT = os.environ.get(
    "K3DM_REPO_ROOT",
    str(Path.home() / "src/gitrepo/personal/k3d-manager")
)
TOKEN_FILE = Path.home() / ".k3dm" / "webhook-token"
JOB_DIR = Path("/tmp/k3dm-webhook-jobs")
SLACK_WEBHOOK_URL = os.environ.get("K3DM_SLACK_WEBHOOK_URL", "")
GEMINI_MODEL = os.environ.get("K3DM_ANALYSIS_MODEL", "gemini-2.5-flash")
_STALL_TICKS_THRESHOLD = 3  # 3 ticks × 2 min = 6 min silence before stall analysis
_running_procs: dict = {}
_running_procs_lock = threading.Lock()


def _get_token():
    token = os.environ.get("K3DM_WEBHOOK_TOKEN")
    if token:
        return token
    try:
        r = subprocess.run(
            ["security", "find-generic-password",
             "-s", "k3dm-webhook-token", "-a", "k3dm", "-w"],
            capture_output=True, text=True
        )
        if r.returncode == 0 and r.stdout.strip():
            return r.stdout.strip()
    except Exception:
        pass
    if TOKEN_FILE.exists():
        return TOKEN_FILE.read_text().strip()
    return None


def _current_label(env, key="argocd-chart-version"):
    r = subprocess.run(
        ["kubectl", "get", "secrets", "-n", "cicd",
         "-l", f"argocd.argoproj.io/secret-type=cluster,environment={env}",
         "-o", f"jsonpath={{.items[0].metadata.labels.{key}}}"],
        capture_output=True, text=True
    )
    return r.stdout.strip()


def _secret_name(env):
    r = subprocess.run(
        ["kubectl", "get", "secrets", "-n", "cicd",
         "-l", f"argocd.argoproj.io/secret-type=cluster,environment={env}",
         "-o", "jsonpath={.items[0].metadata.name}"],
        capture_output=True, text=True
    )
    return r.stdout.strip()


def _patch_label(secret, version):
    patch = json.dumps({"metadata": {"labels": {"argocd-chart-version": version}}})
    subprocess.run(
        ["kubectl", "patch", "secret", secret, "-n", "cicd",
         "--type=merge", "-p", patch],
        check=True
    )


def _run_cleanup(provider):
    """Run make down KEEP_LOCAL=1 in the background after a failed acg-up."""
    _notify(f"🧹 *Cleanup triggered* ({provider}) — running `make down KEEP_LOCAL=1`")
    try:
        cmd = ["make", "down", "KEEP_LOCAL=1"]
        proc = subprocess.Popen(
            cmd,
            cwd=REPO_ROOT,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            preexec_fn=os.setsid,
        )
        pgid = os.getpgid(proc.pid)
        out_lines = []

        def _drain():
            for line in proc.stdout:
                out_lines.append(line)

        reader = threading.Thread(target=_drain, daemon=True)
        reader.start()
        proc.wait()
        try:
            os.killpg(pgid, signal.SIGTERM)
        except (ProcessLookupError, OSError):
            pass
        reader.join(timeout=5)
        if proc.returncode == 0:
            _notify(f"✅ *Cleanup complete* ({provider}) — AWS resources removed")
        else:
            _notify(f"⚠️ *Cleanup failed* ({provider}) — `make down` exited {proc.returncode}; manual teardown may be needed")
    except Exception as exc:
        _notify(f"⚠️ *Cleanup error* ({provider}): {exc}")


def _run_upgrade(job_id, chart_version, stage):
    job_dir = JOB_DIR / job_id
    lines = []

    def _log(msg):
        lines.append(msg + "\n")

    def _finish(status):
        (job_dir / "status").write_text(status)
        (job_dir / "output").write_text("".join(lines))

    try:
        (job_dir / "status").write_text("running")
        env_label = "dev" if stage == "acg" else "infra"

        # Idempotency check
        current = _current_label(env_label)
        if current == chart_version:
            _log(f"{stage}: already at {chart_version} — no-op")
            _finish("success")
            return

        if stage == "acg":
            _log("Running make up...")
            proc = subprocess.Popen(
                ["make", "up"],
                cwd=REPO_ROOT,
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                text=True
            )
            for line in proc.stdout:
                lines.append(line)
            proc.wait()
            if proc.returncode != 0:
                raise RuntimeError(f"make up exited {proc.returncode}")
            _log("make up complete")

        secret = _secret_name(env_label)
        if not secret:
            raise RuntimeError(f"No cluster secret found for environment={env_label}")

        _patch_label(secret, chart_version)
        _log(f"Patched {secret}: argocd-chart-version={chart_version}")
        _finish("success")

    except Exception as exc:
        _log(f"ERROR: {exc}")
        _finish("failed")


def _run_cluster(job_id, action, provider="aws"):
    job_dir = JOB_DIR / job_id
    lines = []
    _provider_map = {"aws": "k3s-aws", "gcp": "k3s-gcp", "azure": "k3s-azure"}
    _cluster_provider = _provider_map.get(provider, "k3s-aws")
    _start = datetime.datetime.utcnow().timestamp()
    _progress_timer = None
    _last_line_count = 0
    _stall_tick_count = 0
    _stall_analyzed = False

    def _log(msg):
        lines.append(msg + "\n")

    def _notify(text):
        _ru_file = job_dir / "response_url"
        url = _ru_file.read_text().strip() if _ru_file.exists() else ""
        if not url:
            url = SLACK_WEBHOOK_URL
        if url:
            _slack_post(url, text)

    def _post_progress():
        nonlocal _progress_timer, _last_line_count, _stall_tick_count, _stall_analyzed
        elapsed = int((datetime.datetime.utcnow().timestamp() - _start) / 60)
        tail = [l.rstrip() for l in lines[-3:] if l.strip()]
        tail_text = "\n".join(tail) if tail else "—"
        _notify(f"⏳ *acg-{action}* ({provider}) still running — {elapsed}m elapsed\n```{tail_text}```")
        current_count = len(lines)
        if current_count == _last_line_count:
            _stall_tick_count += 1
        else:
            _stall_tick_count = 0
            _stall_analyzed = False
        _last_line_count = current_count
        if _stall_tick_count >= _STALL_TICKS_THRESHOLD and not _stall_analyzed:
            _stall_analyzed = True
            analysis = _analyze_stall(lines)
            _notify(
                f"⚠️ *Stall detected* — no new output for {_stall_tick_count * 2}m "
                f"(job `{job_id}`)\n*AI:* {analysis}\n"
                f'To kill: POST `/api/v1/cluster` `{{"action":"kill","job_id":"{job_id}"}}`'
            )
        _progress_timer = threading.Timer(120, _post_progress)
        _progress_timer.daemon = True
        _progress_timer.start()

    def _finish(status):
        if _progress_timer:
            _progress_timer.cancel()
        with _running_procs_lock:
            _running_procs.pop(job_id, None)
        (job_dir / "status").write_text(status)
        (job_dir / "output").write_text("".join(lines))
        emoji = "✅" if status == "success" else "❌"
        elapsed = int((datetime.datetime.utcnow().timestamp() - _start) / 60)
        summary = f"{emoji} *acg-{action}* ({provider}) — {status} in {elapsed}m"
        _notify(summary)

    try:
        if action == "up":
            cmd = ["make", "up", f"CLUSTER_PROVIDER={_cluster_provider}"]
        else:
            cmd = ["make", "down", "KEEP_LOCAL=1"]
        _log(f"Running {' '.join(cmd)}...")
        _progress_timer = threading.Timer(120, _post_progress)
        _progress_timer.daemon = True
        _progress_timer.start()
        proc = subprocess.Popen(
            cmd,
            cwd=REPO_ROOT,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            preexec_fn=os.setsid,
        )
        with _running_procs_lock:
            _running_procs[job_id] = proc

        def _drain():
            for line in proc.stdout:
                lines.append(line)

        _reader = threading.Thread(target=_drain, daemon=True)
        _reader.start()
        pgid = os.getpgid(proc.pid)
        proc.wait()
        try:
            os.killpg(pgid, signal.SIGTERM)
        except (ProcessLookupError, OSError):
            pass
        _reader.join(timeout=5)
        if proc.returncode != 0:
            raise RuntimeError(f"{' '.join(cmd)} exited {proc.returncode}")
        _log(f"{action} complete")
        if action == "up":
            _record_acg_state(provider)
            threading.Thread(
                target=_run_post_provision_check,
                args=(job_id, provider),
                daemon=True
            ).start()
        _finish("success")
    except Exception as exc:
        _log(f"ERROR: {exc}")
        try:
            analysis = _analyze_failure(lines)
            _notify(f"🔍 *Failure analysis* (job `{job_id}`)\n{analysis}")
        except Exception as analysis_exc:
            _log(f"WARN: failure analysis skipped: {analysis_exc}")
        _finish("failed")
        if action == "up":
            threading.Thread(
                target=_run_cleanup,
                args=(provider,),
                daemon=True,
            ).start()


_MAX_JOB_AGE_SECS = 10800  # 3 hours — any older "running" job is stale


def _running_cluster_job():
    """Return (job_id, action) if a cluster up/down job is already running, else None."""
    try:
        now = datetime.datetime.utcnow().timestamp()
        for entry in sorted(JOB_DIR.iterdir(), key=lambda p: p.stat().st_mtime, reverse=True):
            status_file = entry / "status"
            meta_file = entry / "action"
            if status_file.exists() and status_file.read_text().strip() == "running":
                age = now - entry.stat().st_mtime
                if age > _MAX_JOB_AGE_SECS:
                    status_file.write_text("failed")
                    continue
                if meta_file.exists():
                    return (entry.name, meta_file.read_text().strip())
    except Exception:
        pass
    return None


def _record_acg_state(provider):
    """Write provision timestamp to Hub platform-ops ConfigMap."""
    ts = str(int(datetime.datetime.utcnow().timestamp()))
    create = subprocess.run(
        ["kubectl", "create", "configmap", "acg-state",
         f"--from-literal=provisioned-at={ts}",
         f"--from-literal=provider={provider}",
         "-n", "platform-ops",
         "--dry-run=client", "-o", "yaml"],
        capture_output=True, text=True
    )
    if create.returncode == 0:
        subprocess.run(
            ["kubectl", "apply", "-f", "-"],
            input=create.stdout,
            capture_output=True
        )


def _slack_post(url, text):
    """POST a text message to a Slack incoming webhook or response_url."""
    if not url:
        return
    data = json.dumps({"text": text, "response_type": "in_channel"}).encode()
    req = urllib.request.Request(url, data=data,
                                 headers={"Content-Type": "application/json"})
    try:
        urllib.request.urlopen(req, timeout=10)
    except Exception:
        pass


def _call_gemini(prompt):
    """Shell out to the gemini CLI. Returns response text or error string."""
    gemini_bin = os.environ.get("K3DM_GEMINI_BIN", "gemini")
    env = {**os.environ, "GEMINI_CLI_TRUST_WORKSPACE": "true"}
    try:
        r = subprocess.run(
            [gemini_bin, "--model", GEMINI_MODEL, "--prompt", prompt],
            capture_output=True,
            text=True,
            timeout=60,
            env=env,
        )
        return r.stdout.strip() or r.stderr.strip() or "gemini returned no output"
    except FileNotFoundError:
        return "gemini CLI not found — skipping AI analysis"
    except Exception as exc:
        return f"gemini error: {exc}"


def _analyze_stall(lines):
    """Feed last 20 non-empty lines to Claude Haiku; return verdict string."""
    last_20 = [l.rstrip() for l in lines[-20:] if l.strip()]
    last_output = "\n".join(last_20)
    prompt = (
        "acg-up has been running and produced no new output for several minutes. "
        f"Last 20 lines of output:\n\n{last_output}\n\n"
        "Is this process genuinely stalled (no progress, waiting on something that "
        "will not resolve), or is it still doing legitimate work (e.g. waiting for a "
        "pod to become Ready)? "
        "Reply with exactly: STALLED or PROGRESSING, then one sentence why. Be brief."
    )
    return _call_gemini(prompt)


def _collect_cluster_state():
    """Collect live cluster state to enrich failure analysis. Returns a string or empty string."""
    sections = []

    try:
        result = subprocess.run(
            ["kubectl", "get", "pods", "-A", "--context", "ubuntu-k3s", "--no-headers"],
            capture_output=True, text=True, timeout=15,
        )
        if result.returncode == 0 and result.stdout.strip():
            bad = [
                ln for ln in result.stdout.splitlines()
                if any(s in ln for s in (
                    "CrashLoopBackOff", "Error", "OOMKilled",
                    "ImagePullBackOff", "ErrImagePull", "Pending",
                ))
                and "Completed" not in ln
            ]
            if bad:
                sections.append("Unhealthy pods (ubuntu-k3s):\n" + "\n".join(bad))
    except Exception:
        pass

    try:
        result = subprocess.run(
            [
                "kubectl", "get", "applications", "-A",
                "--context", "k3d-k3d-cluster",
                "-o", (
                    "custom-columns="
                    "NAME:.metadata.name,"
                    "HEALTH:.status.health.status,"
                    "SYNC:.status.sync.status"
                ),
                "--no-headers",
            ],
            capture_output=True, text=True, timeout=15,
        )
        if result.returncode == 0 and result.stdout.strip():
            sections.append(
                "ArgoCD application state (k3d-k3d-cluster):\n" + result.stdout.strip()
            )
    except Exception:
        pass

    return "\n\n".join(sections)


def _analyze_failure(lines):
    """Feed last 50 non-empty lines + live cluster state to Gemini; return failure diagnosis."""
    last_50 = [l.rstrip() for l in lines[-50:] if l.strip()]
    last_output = "\n".join(last_50)
    cluster_state = _collect_cluster_state()
    cluster_section = (
        f"Live cluster state at time of failure:\n\n{cluster_state}\n\n"
        if cluster_state else ""
    )
    prompt = (
        "acg-up is a multi-step script that provisions a 3-node k3s cluster on AWS "
        "(via CloudFormation), installs ArgoCD on a local k3d hub cluster, registers "
        "the remote k3s cluster with ArgoCD, then deploys a shopping-cart application "
        "stack (PostgreSQL StatefulSets, Redis, RabbitMQ, Keycloak, Vault, ESO) via "
        "ArgoCD GitOps sync. It failed — make up exited non-zero.\n\n"
        f"Last 50 lines of output:\n\n{last_output}\n\n"
        f"{cluster_section}"
        "Diagnose the failure:\n"
        "1. TRANSIENT or PERMANENT?\n"
        "   TRANSIENT = a retry of acg-up is likely to fix it (e.g. ArgoCD sync lag, "
        "pod not ready yet, API server briefly unreachable).\n"
        "   PERMANENT = human action is required before a retry will work (e.g. "
        "misconfigured manifest, missing secret, quota exceeded, SSH key rejected, "
        "CloudFormation stack in ROLLBACK state).\n"
        "2. Root cause: exactly what component failed and why (name the StatefulSet, "
        "pod, ArgoCD app, or AWS resource if visible in the logs).\n"
        "3. Fix: the single most actionable next step — e.g. 'Run acg-up again', "
        "or 'Check ArgoCD app: kubectl get application data-layer -n cicd --context k3d-k3d-cluster', "
        "or 'Inspect the CloudFormation stack events in the AWS console'.\n\n"
        "Reply in exactly this format:\n"
        "TRANSIENT|PERMANENT\n"
        "<root cause — one sentence>\n"
        "<next step — one sentence, include the exact command if possible>"
    )
    return _call_gemini(prompt)


def _clear_stale_jobs():
    """On startup, mark any job stuck in 'running' as 'failed' — they are orphaned."""
    if not JOB_DIR.exists():
        return
    for entry in JOB_DIR.iterdir():
        status_file = entry / "status"
        try:
            if status_file.exists() and status_file.read_text().strip() == "running":
                status_file.write_text("failed")
                print(f"[k3dm-webhook] cleared stale job {entry.name}")
        except Exception:
            pass


_POST_PROVISION_DELAY_SECS = 90  # ESO sync + pod startup grace period


def _run_post_provision_check(job_id, provider):
    """90s after acg-up: check tunnel + apps; AI-triage each degraded app to Slack."""
    import time
    time.sleep(_POST_PROVISION_DELAY_SECS)

    def _notify(text):
        url = SLACK_WEBHOOK_URL
        if not url:
            _ru_file = JOB_DIR / job_id / "response_url"
            if _ru_file.exists():
                url = _ru_file.read_text().strip()
        if url:
            _slack_post(url, text)

    lines = []

    # SSH tunnel
    tunnel = subprocess.run(
        ["curl", "-sf", "--max-time", "3", "http://localhost:6443"],
        capture_output=True, text=True, timeout=8
    )
    tunnel_ok = tunnel.returncode == 0 or tunnel.returncode == 22
    lines.append(f"*SSH tunnel (6443):* {'UP ✅' if tunnel_ok else 'DOWN ❌'}")

    if not tunnel_ok:
        lines.append("⚠️ Tunnel is down — ACG cluster unreachable; skipping app health check.")
        _notify(f"🏥 *Post-provision check* ({provider})\n" + "\n".join(lines))
        return

    # ArgoCD degraded apps
    apps = subprocess.run(
        ["kubectl", "get", "applications", "-n", "cicd",
         "--context", "k3d-k3d-cluster", "--no-headers",
         "-o", "custom-columns=NAME:.metadata.name,HEALTH:.status.health.status"],
        capture_output=True, text=True, timeout=10
    )
    if apps.returncode != 0 or not apps.stdout.strip():
        lines.append("_ArgoCD app status unavailable_")
        _notify(f"🏥 *Post-provision check* ({provider})\n" + "\n".join(lines))
        return

    app_lines = [l for l in apps.stdout.strip().splitlines() if l]
    degraded = [l.split()[0] for l in app_lines
                if len(l.split()) >= 2 and l.split()[1] == "Degraded"]
    healthy_count = len(app_lines) - len(degraded)
    lines.append(f"*ArgoCD:* {healthy_count}/{len(app_lines)} apps healthy")

    if not degraded:
        _notify(f"🏥 *Post-provision check* ({provider}) — all clear ✅\n" + "\n".join(lines))
        return

    lines.append(f"⚠️ Degraded: {', '.join(f'`{a}`' for a in degraded)}")
    _notify(f"🏥 *Post-provision check* ({provider})\n" + "\n".join(lines))

    # AI triage each degraded app
    for app_name in degraded[:5]:  # cap at 5 to limit API calls
        diag_parts = []

        desc = subprocess.run(
            ["kubectl", "describe", "application", app_name, "-n", "cicd",
             "--context", "k3d-k3d-cluster"],
            capture_output=True, text=True, timeout=15
        )
        if desc.returncode == 0 and desc.stdout.strip():
            diag_parts.append(f"ArgoCD Application:\n{desc.stdout[-2000:]}")

        pods = subprocess.run(
            ["kubectl", "get", "pods", "-A", "--context", "ubuntu-k3s",
             "--no-headers", "--request-timeout=8s",
             "--field-selector=status.phase!=Running"],
            capture_output=True, text=True, timeout=15
        )
        if pods.returncode == 0 and pods.stdout.strip():
            diag_parts.append(f"Non-running pods:\n{pods.stdout.strip()[:1000]}")

        if not diag_parts:
            continue

        prompt = (
            f"A Kubernetes ArgoCD application named '{app_name}' is Degraded "
            f"90 seconds after a fresh cluster provision.\n\n"
            f"Diagnostics:\n" + "\n\n".join(diag_parts) + "\n\n"
            "Is this a TRANSIENT issue (ESO not synced yet, pod still starting — "
            "will resolve in a few minutes) or a REAL FAILURE (misconfiguration, "
            "missing secret, crash loop — needs human action)?\n"
            "Reply with TRANSIENT or REAL FAILURE, then one sentence with the "
            "most likely cause and fix. Be brief."
        )
        analysis = _call_gemini(prompt)
        _notify(f"🔍 *{app_name}* — {analysis}")


def _run_cluster_status(job_id, response_url):
    """Check ACG cluster reachability + ArgoCD app health; post result to response_url."""
    job_dir = JOB_DIR / job_id
    lines = []

    def _log(msg):
        lines.append(msg + "\n")

    def _finish(status):
        (job_dir / "status").write_text(status)
        (job_dir / "output").write_text("".join(lines))
        if response_url:
            _slack_post(response_url, "".join(lines))

    def _pod_is_ready(line):
        parts = line.split()
        if len(parts) < 4:
            return False
        ready_str = parts[2]
        status_str = parts[3]
        if status_str in ("Completed", "Succeeded"):
            return True
        if "/" in ready_str:
            try:
                n, m = ready_str.split("/", 1)
                return n == m and int(m) > 0 and status_str == "Running"
            except ValueError:
                return False
        return False

    try:
        (job_dir / "status").write_text("running")

        active = _running_cluster_job()
        if active:
            active_id, active_action = active
            active_dir = JOB_DIR / active_id
            mtime = active_dir.stat().st_mtime
            elapsed = int((datetime.datetime.utcnow().timestamp() - mtime) / 60)
            _log(f"⏳ *acg-{active_action}* in progress (running {elapsed}m) — job `{active_id}`")
            _finish("success")
            return

        # Hub cluster
        hub_nodes = subprocess.run(
            ["kubectl", "get", "nodes", "--context", "k3d-k3d-cluster",
             "--request-timeout=5s", "--no-headers"],
            capture_output=True, text=True, timeout=10
        )
        if hub_nodes.returncode == 0 and hub_nodes.stdout.strip():
            hub_lines = [l for l in hub_nodes.stdout.strip().splitlines() if l]
            hub_ready = sum(1 for l in hub_lines if "Ready" in l and "NotReady" not in l)
            _log(f"🏠 *Hub cluster* — {hub_ready}/{len(hub_lines)} nodes ready")
        else:
            _log("🏠 *Hub cluster* — ❌ unreachable")

        # SSH tunnel
        tunnel = subprocess.run(
            ["curl", "-sf", "--max-time", "3", "http://localhost:6443"],
            capture_output=True, text=True, timeout=8
        )
        tunnel_ok = tunnel.returncode == 0 or tunnel.returncode == 22
        _log(f"*SSH tunnel (6443):* {'UP ✅' if tunnel_ok else 'DOWN ❌'}")

        # ACG app cluster
        nodes = subprocess.run(
            ["kubectl", "get", "nodes", "--context", "ubuntu-k3s",
             "--request-timeout=8s", "--no-headers"],
            capture_output=True, text=True, timeout=15
        )
        if nodes.returncode != 0:
            _log("\n❌ *ACG cluster unreachable* — sandbox may have expired.")
            _finish("success")
            return

        node_lines = [l for l in nodes.stdout.strip().splitlines() if l]
        ready_count = sum(1 for l in node_lines if "Ready" in l and "NotReady" not in l)
        total_count = len(node_lines)

        header = f"\n✅ *ACG cluster* — {ready_count}/{total_count} nodes ready"
        acg_state = subprocess.run(
            ["kubectl", "get", "configmap", "acg-state", "-n", "platform-ops",
             "--context", "ubuntu-k3s", "--request-timeout=5s",
             "-o", "jsonpath={.data.provisioned-at} {.data.provider}"],
            capture_output=True, text=True, timeout=10
        )
        if acg_state.returncode == 0 and acg_state.stdout.strip():
            parts = acg_state.stdout.strip().split()
            try:
                age_min = int((datetime.datetime.utcnow().timestamp() - int(parts[0])) / 60)
                provider = parts[1] if len(parts) > 1 else "aws"
                header += f" | {provider} | up {age_min}m"
            except (ValueError, IndexError):
                pass
        _log(header)
        _log(f"```{nodes.stdout.strip()}```")

        # ACG pods (all namespaces, standard output)
        pods = subprocess.run(
            ["kubectl", "get", "pods", "-A", "--context", "ubuntu-k3s",
             "--no-headers", "--request-timeout=10s"],
            capture_output=True, text=True, timeout=20
        )
        if pods.returncode == 0 and pods.stdout.strip():
            all_pod_lines = [l for l in pods.stdout.strip().splitlines() if l]
            skip_ns = {"kube-system", "kube-public", "kube-node-lease", "trivy-system"}
            app_pods = [l for l in all_pod_lines if l.split()[0] not in skip_ns]
            if app_pods:
                not_ready = [l for l in app_pods if not _pod_is_ready(l)]
                ready_count_pods = len(app_pods) - len(not_ready)
                _log(f"\n*Pods (ACG)* — {ready_count_pods}/{len(app_pods)} ready")
                if not_ready:
                    shown = not_ready[:10]
                    snippet = "\n".join(
                        f"{l.split()[0]}  {l.split()[1]}  {l.split()[2]}  {l.split()[3]}"
                        for l in shown if len(l.split()) >= 4
                    )
                    _log(f"```{snippet}```")
                    if len(not_ready) > 10:
                        _log(f"_…and {len(not_ready) - 10} more not-ready pods_")
            else:
                _log("\n*Pods (ACG)* — no app pods deployed yet")
        else:
            _log("\n_Pod status unavailable_")

        # ArgoCD apps
        apps = subprocess.run(
            ["kubectl", "get", "applications", "-n", "cicd",
             "--context", "k3d-k3d-cluster",
             "--no-headers",
             "-o", "custom-columns=NAME:.metadata.name,SYNC:.status.sync.status,HEALTH:.status.health.status"],
            capture_output=True, text=True, timeout=10
        )
        if apps.returncode == 0 and apps.stdout.strip():
            acg_apps = [l for l in apps.stdout.strip().splitlines()
                        if l.startswith("acg-") or "ubuntu-k3s" in l]
            if acg_apps:
                _log("\n*ACG ArgoCD apps:*")
                _log(f"```{chr(10).join(acg_apps)}```")
            all_apps = apps.stdout.strip().splitlines()
            unhealthy = [l for l in all_apps
                         if "Degraded" in l or "Missing" in l or "OutOfSync" in l]
            if unhealthy:
                _log("\n⚠️ *Unhealthy/OutOfSync apps:*")
                _log(f"```{chr(10).join(unhealthy)}```")
        else:
            _log("\n_ArgoCD app status unavailable (Hub cluster unreachable)_")

        # AWS credentials
        aws_id = subprocess.run(
            ["aws", "sts", "get-caller-identity",
             "--query", "Arn", "--output", "text"],
            capture_output=True, text=True, timeout=10
        )
        if aws_id.returncode == 0 and aws_id.stdout.strip():
            _log(f"\n*AWS:* ✅ `{aws_id.stdout.strip()}`")
        else:
            _log("\n*AWS:* ❌ credentials invalid or expired — run `/acg-refresh`")

        _finish("success")
    except Exception as exc:
        _log(f"ERROR: {exc}")
        _finish("failed")


def _run_analyze(job_id, alert_payload, response_url=""):
    """Gather kubectl diagnostics for firing alerts; call Claude; post to Slack."""
    job_dir = JOB_DIR / job_id
    lines = []

    def _log(msg):
        lines.append(msg + "\n")

    def _finish(status):
        (job_dir / "status").write_text(status)
        (job_dir / "output").write_text("".join(lines))

    try:
        (job_dir / "status").write_text("running")
        alerts = alert_payload.get("alerts", [])
        firing = [a for a in alerts if a.get("status") == "firing"]
        if not firing:
            _finish("success")
            return

        for alert in firing:
            app_name = alert.get("labels", {}).get("name", "")
            alert_name = alert.get("labels", {}).get("alertname", "unknown")
            _log(f"=== {alert_name}: {app_name} ===\n")

            diag_parts = []
            if app_name:
                desc = subprocess.run(
                    ["kubectl", "describe", "application", app_name, "-n", "cicd"],
                    capture_output=True, text=True
                )
                if desc.returncode == 0:
                    diag_parts.append(f"ArgoCD Application:\n{desc.stdout[-3000:]}")

            pods = subprocess.run(
                ["kubectl", "get", "pods", "-A",
                 "--field-selector=status.phase!=Running",
                 "--no-headers"],
                capture_output=True, text=True
            )
            if pods.returncode == 0 and pods.stdout.strip():
                diag_parts.append(f"Non-running pods:\n{pods.stdout.strip()}")

            if not diag_parts:
                _log("No diagnostics gathered\n")
                continue

            diagnostics = "\n\n".join(diag_parts)
            prompt = (
                f"You are a Kubernetes operations expert. Analyze this alert and give a "
                f"concise diagnosis (2-3 sentences) and the single most likely fix.\n\n"
                f"Alert: {alert_name} on app '{app_name}'\n\n"
                f"Diagnostics:\n{diagnostics}"
            )
            analysis = _call_gemini(prompt)
            _log(analysis + "\n")

            notify_url = response_url or SLACK_WEBHOOK_URL
            if notify_url:
                _slack_post(notify_url,
                    f"🔍 *{alert_name}* — `{app_name}`\n{analysis}")

        _finish("success")
    except Exception as exc:
        _log(f"ERROR: {exc}")
        _finish("failed")


class _Handler(http.server.BaseHTTPRequestHandler):
    def _auth(self):
        token = _get_token()
        if not token:
            return False
        return hmac.compare_digest(
            self.headers.get("Authorization", ""),
            f"Bearer {token}"
        )

    def _json(self, code, body):
        data = json.dumps(body, separators=(",", ":")).encode()
        self.send_response(code)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(data)))
        self.end_headers()
        self.wfile.write(data)

    def do_POST(self):
        if not self._auth():
            self._json(401, {"error": "unauthorized"})
            return
        if self.path.startswith("/api/") and not self.path.startswith("/api/v1/"):
            self._json(400, {"error": "invalid api path"})
            return

        length = int(self.headers.get("Content-Length", 0))
        if length > MAX_BODY:
            self._json(413, {"error": "request too large"})
            return
        body = json.loads(self.rfile.read(length) or b"{}")
        if self.path == "/api/v1/argocd-upgrade":
            chart_version = body.get("chart_version", "")
            stage = body.get("stage", "")
            if not chart_version or stage not in ("acg", "infra"):
                self._json(400, {"error": "chart_version and stage (acg|infra) required"})
                return
            job_id = str(uuid.uuid4())[:8]
            (JOB_DIR / job_id).mkdir(parents=True, exist_ok=True)
            (JOB_DIR / job_id / "status").write_text("queued")
            threading.Thread(
                target=_run_upgrade,
                args=(job_id, chart_version, stage),
                daemon=True
            ).start()
            self._json(202, {"job_id": job_id, "status": "queued"})
            return

        if self.path == "/api/v1/cluster":
            action = body.get("action", "")
            if action == "kill":
                job_id = body.get("job_id", "")
                if not job_id or not _JOB_ID_RE.match(job_id):
                    self._json(400, {"error": "job_id required"})
                    return
                with _running_procs_lock:
                    proc = _running_procs.get(job_id)
                if proc:
                    proc.kill()
                    job_dir = JOB_DIR / job_id
                    (job_dir / "status").write_text("killed")
                    self._json(200, {"status": "killed", "job_id": job_id})
                else:
                    self._json(404, {"error": "no running job", "job_id": job_id})
                return
            if action not in ("up", "down"):
                self._json(400, {"error": "action (up|down|kill) required"})
                return
            running = _running_cluster_job()
            if running:
                self._json(409, {"error": f"cluster job already running: {running[0]} ({running[1]})"})
                return
            provider = body.get("provider", "aws")
            if provider not in ("aws", "gcp", "azure"):
                provider = "aws"
            response_url = body.get("response_url", "")
            job_id = str(uuid.uuid4())[:8]
            (JOB_DIR / job_id).mkdir(parents=True, exist_ok=True)
            (JOB_DIR / job_id / "status").write_text("running")
            (JOB_DIR / job_id / "action").write_text(action)
            if response_url:
                (JOB_DIR / job_id / "response_url").write_text(response_url)
            threading.Thread(
                target=_run_cluster,
                args=(job_id, action, provider),
                daemon=True
            ).start()
            self._json(202, {"job_id": job_id, "status": "queued"})
            return

        if self.path == "/api/v1/cluster-status":
            response_url = body.get("response_url", "")
            job_id = str(uuid.uuid4())[:8]
            (JOB_DIR / job_id).mkdir(parents=True, exist_ok=True)
            (JOB_DIR / job_id / "status").write_text("queued")
            threading.Thread(
                target=_run_cluster_status,
                args=(job_id, response_url),
                daemon=True
            ).start()
            self._json(202, {"job_id": job_id, "status": "queued"})
            return

        if self.path == "/api/v1/analyze":
            response_url = body.get("response_url", "")
            job_id = str(uuid.uuid4())[:8]
            (JOB_DIR / job_id).mkdir(parents=True, exist_ok=True)
            (JOB_DIR / job_id / "status").write_text("queued")
            threading.Thread(
                target=_run_analyze,
                args=(job_id, body, response_url),
                daemon=True
            ).start()
            self._json(202, {"job_id": job_id, "status": "queued"})
            return

        self._json(404, {"error": "not found"})

    def do_GET(self):
        if not self._auth():
            self._json(401, {"error": "unauthorized"})
            return
        if self.path.startswith("/api/") and not self.path.startswith("/api/v1/"):
            self._json(400, {"error": "invalid api path"})
            return
        if not self.path.startswith("/api/v1/status/"):
            self._json(404, {"error": "not found"})
            return

        job_id = self.path.rsplit("/", 1)[-1]
        if not _JOB_ID_RE.match(job_id):
            self._json(400, {"error": "invalid job id"})
            return
        job_dir = JOB_DIR / job_id
        if not job_dir.exists():
            self._json(404, {"error": "job not found"})
            return

        status = (job_dir / "status").read_text().strip()
        output_file = job_dir / "output"
        output = output_file.read_text()[-2000:] if output_file.exists() else ""
        self._json(200, {"job_id": job_id, "status": status, "output": output})

    def log_message(self, *_):
        pass  # suppress access log noise


if __name__ == "__main__":
    JOB_DIR.mkdir(parents=True, exist_ok=True)
    _clear_stale_jobs()
    server = http.server.ThreadingHTTPServer(("127.0.0.1", PORT), _Handler)
    print(f"[k3dm-webhook] listening on 127.0.0.1:{PORT}")
    server.serve_forever()
