#!/usr/bin/env bash
set -euo pipefail

K3DM_STATE_DIR="${HOME}/.local/share/k3d-manager"

# Failure screenshots — keep most recent 10 in root, 10 in logs/
_prune_pngs() {
  local dir="$1"
  local keep="${2:-10}"
  local count
  count=$(ls -1t "${dir}"/acg-extend-failure-*.png 2>/dev/null | wc -l | tr -d ' ')
  if [[ "${count}" -gt "${keep}" ]]; then
    ls -1t "${dir}"/acg-extend-failure-*.png | tail -n "+$((keep + 1))" | xargs rm -f
    echo "k3dm-cleanup: pruned $((count - keep)) failure PNGs from ${dir}"
  fi
}

# Chromium re-downloadable cache dirs — safe to delete; browser re-creates them
_prune_chromium_cache() {
  local profile_dir="$1"
  local -a cache_dirs=(
    component_crx_cache
    optimization_guide_model_store
    GraphiteDawnCache
    WasmTtsEngine
    "Safe Browsing"
  )
  local cache_dir target
  for cache_dir in "${cache_dirs[@]}"; do
    target="${profile_dir}/${cache_dir}"
    if [[ -d "${target}" ]]; then
      rm -rf "${target}"
      echo "k3dm-cleanup: removed Chromium cache ${target}"
    fi
  done
}

_prune_pngs "${K3DM_STATE_DIR}"
_prune_pngs "${K3DM_STATE_DIR}/logs"
_prune_chromium_cache "${K3DM_STATE_DIR}/profile"
_prune_chromium_cache "${K3DM_STATE_DIR}/playwright-auth"

# /tmp screenshots — keep most recent 5; delete older ones
_tmp_ss_count=$(ls -1t /tmp/k3dm-acg-screenshot-*.png 2>/dev/null | wc -l | tr -d ' ')
if [[ "${_tmp_ss_count}" -gt 5 ]]; then
  ls -1t /tmp/k3dm-acg-screenshot-*.png | tail -n "+6" | xargs rm -f
  echo "k3dm-cleanup: pruned $(( _tmp_ss_count - 5 )) screenshot(s) from /tmp"
fi

# Playwright artifact dirs — delete any older than 1 day
find /tmp -maxdepth 1 -name 'playwright-artifacts-*' -type d -mtime +1 -exec rm -rf {} + 2>/dev/null || true
echo "k3dm-cleanup: pruned stale playwright-artifacts dirs from /tmp"

echo "k3dm-cleanup: done"
