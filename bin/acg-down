#!/usr/bin/env bash
# bin/acg-down
#
# Tear down the ACG cluster — stop tunnel (AWS), delete remote cluster, stop Vault PF.
# Requires --confirm to prevent accidental teardown.
#
# Usage:
#   bin/acg-down --confirm [--keep-hub]
#
# Environment:
#   CLUSTER_PROVIDER   k3s-aws (default) or k3s-gcp
#   ACG_REGION         AWS region (default: us-west-2)
#   GCP_PROJECT        GCP project ID (required when CLUSTER_PROVIDER=k3s-gcp)

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SCRIPT_DIR="${REPO_ROOT}/scripts"
source "${REPO_ROOT}/scripts/lib/system.sh"
source "${REPO_ROOT}/scripts/lib/core.sh"

: "${SCRIPT_DIR}"

_cluster_provider="${CLUSTER_PROVIDER:-k3s-aws}"
_confirm=0
_keep_hub=0
_HUB_CLUSTER="${HUB_CLUSTER_NAME:-k3d-cluster}"
for _arg in "$@"; do
  case "${_arg}" in
    --confirm)  _confirm=1 ;;
    --keep-hub) _keep_hub=1 ;;
  esac
done

if [[ "${_confirm}" -eq 0 ]]; then
  echo "Usage: bin/acg-down --confirm [--keep-hub]"
  echo ""
  echo "  --confirm    Required. Tears down remote cluster and local Hub cluster."
  echo "  --keep-hub   Optional. Skip local Hub (k3d-cluster) teardown."
  exit 1
fi

_info "[acg-down] keep-hub=${_keep_hub} hub-cluster=${_HUB_CLUSTER}"

case "${_cluster_provider}" in
  k3s-aws)
    source "${REPO_ROOT}/scripts/plugins/aws.sh"
    source "${REPO_ROOT}/scripts/plugins/acg.sh"
    source "${REPO_ROOT}/scripts/plugins/tunnel.sh"
    _info "[acg-down] Clearing local port-forwarding processes (8080, 18080, 18200)..."
lsof -ti :8080,18080,18200 | xargs kill -9 2>/dev/null || true

_info "[acg-down] Stopping tunnel..."
    tunnel_stop 2>/dev/null || true
    _info "[acg-down] Tearing down CloudFormation stack (AWS)..."
    if aws sts get-caller-identity --region "${ACG_REGION}" --query 'Arn' --output text >/dev/null 2>&1; then
      acg_teardown --confirm || \
        _info "[acg-down] CloudFormation teardown failed — sandbox may have been recreated with new credentials. Stack cleanup skipped; continuing Hub teardown."
    else
      _info "[acg-down] AWS credentials invalid or expired — sandbox already removed. Skipping CloudFormation teardown."
    fi
    ;;
  k3s-gcp)
    source "${REPO_ROOT}/scripts/lib/providers/k3s-gcp.sh"
    _info "[acg-down] Tearing down GCP cluster..."
    if [[ -z "${GCP_PROJECT:-}" ]]; then
      _gcp_sa_json="${HOME}/.local/share/k3d-manager/gcp-service-account.json"
      if [[ -f "${_gcp_sa_json}" ]]; then
        GCP_PROJECT="$(python3 -c "import json; print(json.load(open('${_gcp_sa_json}')).get('project_id',''))" 2>/dev/null || true)"
        export GCP_PROJECT
      fi
    fi
    _provider_k3s_gcp_destroy_cluster --confirm
    ;;
  *)
    _info "[acg-down] Unknown CLUSTER_PROVIDER '${_cluster_provider}' — skipping remote teardown"
    ;;
esac

_info "[acg-down] Stopping Vault port-forward..."
_vault_pf_pid_file="${HOME}/.local/share/k3d-manager/vault-pf.pid"
if [[ -f "${_vault_pf_pid_file}" ]]; then
  kill "$(cat "${_vault_pf_pid_file}")" 2>/dev/null || true
  rm -f "${_vault_pf_pid_file}"
  _info "[acg-down] Vault port-forward stopped"
fi

_info "[acg-down] Stopping frontend port-forward..."
_frontend_pf_pid_file="${HOME}/.local/share/k3d-manager/frontend-pf.pid"
if [[ -f "${_frontend_pf_pid_file}" ]]; then
  kill "$(cat "${_frontend_pf_pid_file}")" 2>/dev/null || true
  rm -f "${_frontend_pf_pid_file}"
  _info "[acg-down] Frontend port-forward stopped"
fi

_info "[acg-down] Stopping ArgoCD port-forward launchd agent..."
_argocd_pf_label="com.k3d-manager.argocd-port-forward"
_argocd_pf_plist="${HOME}/Library/LaunchAgents/${_argocd_pf_label}.plist"
if launchctl list "${_argocd_pf_label}" >/dev/null 2>&1; then
  launchctl unload "${_argocd_pf_plist}" 2>/dev/null || true
  _info "[acg-down] ArgoCD port-forward launchd agent unloaded"
fi
rm -f "${_argocd_pf_plist}"

if _is_mac; then
  _info "[acg-down] Stopping Keycloak browser HTTP listener launchd daemon..."
  _keycloak_browser_label="com.k3d-manager.keycloak-browser-http"
  _keycloak_browser_plist="${KEYCLOAK_BROWSER_LISTENER_PLIST:-/Library/LaunchDaemons/${_keycloak_browser_label}.plist}"
  _keycloak_browser_wrapper="${HOME}/.local/share/k3d-manager/keycloak-browser-http.sh"
  _keycloak_browser_log="${HOME}/.local/share/k3d-manager/keycloak-browser-http.log"
  _keycloak_browser_launchctl_log="${HOME}/.local/share/k3d-manager/keycloak-browser-http-launchctl.log"
  if _run_command --interactive-sudo --soft -- launchctl bootout system "${_keycloak_browser_plist}" \
      >"${_keycloak_browser_launchctl_log}" 2>&1; then
    _info "[acg-down] Keycloak browser HTTP listener launchd daemon unloaded"
  elif [[ -s "${_keycloak_browser_launchctl_log}" ]]; then
    tail -n 20 "${_keycloak_browser_launchctl_log}" >&2 || true
    _warn "[acg-down] existing Keycloak browser HTTP listener was not loaded; continuing"
  fi
  _run_command --interactive-sudo --soft -- rm -f "${_keycloak_browser_plist}" "${_keycloak_browser_wrapper}" >/dev/null 2>&1 || true

  _info "[acg-down] Stopping ArgoCD browser HTTPS listener launchd daemon..."
  _argocd_browser_label="${ARGOCD_BROWSER_LISTENER_LABEL:-com.k3d-manager.argocd-browser-https}"
  _argocd_browser_plist="${ARGOCD_BROWSER_LISTENER_PLIST:-/Library/LaunchDaemons/${_argocd_browser_label}.plist}"
  _argocd_browser_wrapper="${ARGOCD_BROWSER_LISTENER_WRAPPER:-${HOME}/.local/share/k3d-manager/argocd-browser-https.sh}"
  _argocd_browser_tls_dir="${ARGOCD_BROWSER_TLS_DIR:-${HOME}/.local/share/k3d-manager/argocd-browser-https-tls}"
  _argocd_browser_tls_cert="${ARGOCD_BROWSER_TLS_CERT_FILE:-${_argocd_browser_tls_dir}/fullchain.crt}"
  _argocd_browser_tls_key="${ARGOCD_BROWSER_TLS_KEY_FILE:-${_argocd_browser_tls_dir}/tls.key}"
  _argocd_browser_tls_ca="${ARGOCD_BROWSER_TLS_CA_FILE:-${_argocd_browser_tls_dir}/ca.crt}"
  if _run_command --interactive-sudo -- launchctl bootout system "${_argocd_browser_plist}" 2>/dev/null; then
    _info "[acg-down] ArgoCD browser HTTPS listener launchd daemon unloaded"
  fi
  _run_command --interactive-sudo --soft -- rm -f "${_argocd_browser_plist}" "${_argocd_browser_wrapper}" >/dev/null 2>&1 || true
  _run_command --interactive-sudo --soft -- rm -f "${_argocd_browser_tls_cert}" "${_argocd_browser_tls_key}" "${_argocd_browser_tls_ca}" "${_argocd_browser_tls_dir}/tls.crt" >/dev/null 2>&1 || true
fi

if [[ "${_keep_hub}" -eq 0 ]]; then
  _info "[acg-down] Tearing down local Hub cluster (${_HUB_CLUSTER})..."
  if k3d cluster list 2>/dev/null | grep -q "^${_HUB_CLUSTER}[[:space:]]"; then
    k3d cluster delete "${_HUB_CLUSTER}"
    _info "[acg-down] Local Hub cluster deleted"
  else
    _info "[acg-down] Local Hub cluster not found — skipping"
  fi
else
  _info "[acg-down] --keep-hub set — local Hub cluster preserved"
fi

if [[ "${_keep_hub}" -eq 1 ]]; then
  _info "[acg-down] Done. Remote cluster deleted; local Hub preserved."
else
  _info "[acg-down] Done. Remote cluster and local Hub deleted."
fi
