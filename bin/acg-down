#!/usr/bin/env bash
# bin/acg-down
#
# Tear down the ACG cluster — stop tunnel (AWS), delete remote cluster, stop Vault PF.
# Requires --confirm to prevent accidental teardown.
#
# Usage:
#   bin/acg-down --confirm [--keep-hub]
#
# Environment:
#   CLUSTER_PROVIDER   k3s-aws (default) or k3s-gcp
#   ACG_REGION         AWS region (default: us-west-2)
#   GCP_PROJECT        GCP project ID (required when CLUSTER_PROVIDER=k3s-gcp)

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SCRIPT_DIR="${REPO_ROOT}/scripts"
source "${REPO_ROOT}/scripts/lib/system.sh"
source "${REPO_ROOT}/scripts/lib/core.sh"
_ACG_STATE_DIR="${HOME}/.local/share/k3d-manager"
mkdir -p "${_ACG_STATE_DIR}/run" "${_ACG_STATE_DIR}/logs"

: "${SCRIPT_DIR}"

_cluster_provider="${CLUSTER_PROVIDER:-k3s-aws}"
_confirm=0
_keep_hub=0
_HUB_CLUSTER="${HUB_CLUSTER_NAME:-k3d-cluster}"
for _arg in "$@"; do
  case "${_arg}" in
    --confirm)  _confirm=1 ;;
    --keep-hub) _keep_hub=1 ;;
  esac
done

if [[ "${_confirm}" -eq 0 ]]; then
  echo "Usage: bin/acg-down --confirm [--keep-hub]"
  echo ""
  echo "  --confirm    Required. Tears down remote cluster and local Hub cluster."
  echo "  --keep-hub   Optional. Skip local Hub (k3d-cluster) teardown."
  exit 1
fi

_info "[acg-down] keep-hub=${_keep_hub} hub-cluster=${_HUB_CLUSTER}"

case "${_cluster_provider}" in
  k3s-aws)
    source "${REPO_ROOT}/scripts/plugins/aws.sh"
    source "${REPO_ROOT}/scripts/plugins/acg.sh"
    source "${REPO_ROOT}/scripts/plugins/tunnel.sh"
    _info "[acg-down] Clearing local port-forwarding processes (8080, 18080, 18200)..."
lsof -ti :8080,18080,18200 | xargs kill -9 2>/dev/null || true

_info "[acg-down] Stopping tunnel..."
    tunnel_stop 2>/dev/null || true
    _info "[acg-down] Tearing down CloudFormation stack (AWS)..."
    if aws sts get-caller-identity --region "${ACG_REGION}" --query 'Arn' --output text >/dev/null 2>&1; then
      acg_teardown --confirm || \
        _info "[acg-down] CloudFormation teardown failed — sandbox may have been recreated with new credentials. Stack cleanup skipped; continuing Hub teardown."
    else
      _info "[acg-down] AWS credentials invalid or expired — sandbox already removed. Skipping CloudFormation teardown."
    fi
    ;;
  k3s-gcp)
    source "${REPO_ROOT}/scripts/lib/providers/k3s-gcp.sh"
    _info "[acg-down] Tearing down GCP cluster..."
    if [[ -z "${GCP_PROJECT:-}" ]]; then
      _gcp_sa_json="${HOME}/.local/share/k3d-manager/gcp-service-account.json"
      if [[ -f "${_gcp_sa_json}" ]]; then
        GCP_PROJECT="$(python3 -c "import json; print(json.load(open('${_gcp_sa_json}')).get('project_id',''))" 2>/dev/null || true)"
        export GCP_PROJECT
      fi
    fi
    _provider_k3s_gcp_destroy_cluster --confirm
    ;;
  *)
    _info "[acg-down] Unknown CLUSTER_PROVIDER '${_cluster_provider}' — skipping remote teardown"
    ;;
esac

_info "[acg-down] Stopping Vault port-forward..."
_vault_pf_pid_file="${_ACG_STATE_DIR}/run/vault-pf.pid"
if [[ -f "${_vault_pf_pid_file}" ]]; then
  kill "$(cat "${_vault_pf_pid_file}")" 2>/dev/null || true
  rm -f "${_vault_pf_pid_file}"
  _info "[acg-down] Vault port-forward stopped"
fi
if _is_mac; then
  _vault_pf_label="com.k3d-manager.vault-port-forward"
  _vault_pf_plist="${HOME}/Library/LaunchAgents/${_vault_pf_label}.plist"
  if launchctl list "${_vault_pf_label}" >/dev/null 2>&1; then
    launchctl unload "${_vault_pf_plist}" 2>/dev/null || true
    _info "[acg-down] Vault port-forward LaunchAgent unloaded"
  fi
  rm -f "${_vault_pf_plist}"
fi

_info "[acg-down] Stopping frontend port-forward..."
_frontend_pf_pid_file="${_ACG_STATE_DIR}/run/frontend-pf.pid"
if [[ -f "${_frontend_pf_pid_file}" ]]; then
  kill "$(cat "${_frontend_pf_pid_file}")" 2>/dev/null || true
  rm -f "${_frontend_pf_pid_file}"
  _info "[acg-down] Frontend port-forward stopped"
fi

_info "[acg-down] Stopping ACG Prometheus port-forward..."
_acg_prom_pf_pid_file="${_ACG_STATE_DIR}/run/acg-prom-pf.pid"
if [[ -f "${_acg_prom_pf_pid_file}" ]]; then
  kill "$(cat "${_acg_prom_pf_pid_file}")" 2>/dev/null || true
  rm -f "${_acg_prom_pf_pid_file}"
  _info "[acg-down] ACG Prometheus port-forward stopped"
fi

_info "[acg-down] Stopping ArgoCD port-forward launchd agent..."
_argocd_pf_label="com.k3d-manager.argocd-port-forward"
_argocd_pf_plist="${HOME}/Library/LaunchAgents/${_argocd_pf_label}.plist"
if launchctl list "${_argocd_pf_label}" >/dev/null 2>&1; then
  launchctl unload "${_argocd_pf_plist}" 2>/dev/null || true
  _info "[acg-down] ArgoCD port-forward launchd agent unloaded"
fi
rm -f "${_argocd_pf_plist}"

if _is_mac; then
  _info "[acg-down] Stopping Keycloak browser HTTP listener launchd daemon..."
  _keycloak_browser_label="com.k3d-manager.keycloak-browser-http"
  _keycloak_browser_plist="${KEYCLOAK_BROWSER_LISTENER_PLIST:-/Library/LaunchDaemons/${_keycloak_browser_label}.plist}"
  _keycloak_browser_wrapper="${HOME}/.local/share/k3d-manager/keycloak-browser-http.sh"
  _keycloak_browser_log="${HOME}/.local/share/k3d-manager/keycloak-browser-http.log"
  _keycloak_browser_launchctl_log="${HOME}/.local/share/k3d-manager/keycloak-browser-http-launchctl.log"
  if ! sudo -n true 2>/dev/null && ! [[ -t 0 && -t 1 ]]; then
    _warn "[acg-down] no sudo in headless context — skipping keycloak-browser-http LaunchDaemon bootout"
  else
    if _run_command --prefer-sudo --soft -- launchctl bootout system "${_keycloak_browser_plist}" \
        >"${_keycloak_browser_launchctl_log}" 2>&1; then
      _info "[acg-down] Keycloak browser HTTP listener launchd daemon unloaded"
    elif [[ -s "${_keycloak_browser_launchctl_log}" ]]; then
      tail -n 20 "${_keycloak_browser_launchctl_log}" >&2 || true
      _warn "[acg-down] existing Keycloak browser HTTP listener was not loaded; continuing"
    fi
  fi
  _run_command --prefer-sudo --soft -- rm -f "${_keycloak_browser_plist}" "${_keycloak_browser_wrapper}" >/dev/null 2>&1 || true

  _info "[acg-down] Stopping ArgoCD browser HTTPS listener launchd daemon..."
  _argocd_browser_label="${ARGOCD_BROWSER_LISTENER_LABEL:-com.k3d-manager.argocd-browser-https}"
  _argocd_browser_plist="${ARGOCD_BROWSER_LISTENER_PLIST:-/Library/LaunchDaemons/${_argocd_browser_label}.plist}"
  _argocd_browser_wrapper="${ARGOCD_BROWSER_LISTENER_WRAPPER:-${_ACG_STATE_DIR}/bin/argocd-browser-https.sh}"
  _argocd_browser_tls_dir="${ARGOCD_BROWSER_TLS_DIR:-${_ACG_STATE_DIR}/argocd-browser-https-tls}"
  _argocd_browser_tls_cert="${ARGOCD_BROWSER_TLS_CERT_FILE:-${_argocd_browser_tls_dir}/fullchain.crt}"
  _argocd_browser_tls_key="${ARGOCD_BROWSER_TLS_KEY_FILE:-${_argocd_browser_tls_dir}/tls.key}"
  _argocd_browser_tls_ca="${ARGOCD_BROWSER_TLS_CA_FILE:-${_argocd_browser_tls_dir}/ca.crt}"
  _argocd_browser_launchctl_log="${_ACG_STATE_DIR}/logs/argocd-browser-https-launchctl.log"
  : > "${_argocd_browser_launchctl_log}"
  if ! sudo -n true 2>/dev/null && ! [[ -t 0 && -t 1 ]]; then
    _warn "[acg-down] no sudo in headless context — skipping argocd-browser-https LaunchDaemon bootout"
  else
    if _run_command --prefer-sudo --quiet --soft -- launchctl bootout system "${_argocd_browser_plist}" \
        >"${_argocd_browser_launchctl_log}" 2>&1; then
      _info "[acg-down] ArgoCD browser HTTPS listener launchd daemon unloaded"
    elif [[ -s "${_argocd_browser_launchctl_log}" ]]; then
      tail -n 20 "${_argocd_browser_launchctl_log}" >&2 || true
      _warn "[acg-down] existing ArgoCD browser HTTPS listener was not loaded; continuing"
    fi
  fi
  _run_command --prefer-sudo --soft -- rm -f "${_argocd_browser_plist}" "${_argocd_browser_wrapper}" >/dev/null 2>&1 || true
  _run_command --prefer-sudo --soft -- rm -f "${_argocd_browser_tls_cert}" "${_argocd_browser_tls_key}" "${_argocd_browser_tls_ca}" "${_argocd_browser_tls_dir}/tls.crt" >/dev/null 2>&1 || true

  _info "[acg-down] Stopping Cloudflare named tunnel launchd agent..."
  _cf_tunnel_plist="${HOME}/Library/LaunchAgents/com.k3d-manager.cloudflare-tunnel.plist"
  _cf_tunnel_launchctl_log="${_ACG_STATE_DIR}/logs/cloudflare-tunnel-launchctl.log"
  : > "${_cf_tunnel_launchctl_log}"
  if launchctl bootout "gui/$(id -u)" "${_cf_tunnel_plist}" \
      >"${_cf_tunnel_launchctl_log}" 2>&1; then
    _info "[acg-down] Cloudflare named tunnel launchd agent unloaded"
  fi
  rm -f "${_cf_tunnel_plist}" || true
  _cf_tunnel_plist_legacy="/Library/LaunchDaemons/com.k3d-manager.cloudflare-tunnel.plist"
  if [[ -f "${_cf_tunnel_plist_legacy}" ]]; then
    _run_command --prefer-sudo --quiet --soft -- launchctl bootout system "${_cf_tunnel_plist_legacy}" \
      >/dev/null 2>&1 || true
    _run_command --prefer-sudo --quiet --soft -- rm -f "${_cf_tunnel_plist_legacy}" \
      >/dev/null 2>&1 || true
  fi

  _info "[acg-down] Stopping frontend browser HTTP listener launchd daemon..."
  _frontend_browser_plist="${FRONTEND_BROWSER_LISTENER_PLIST:-/Library/LaunchDaemons/com.k3d-manager.frontend-browser-http.plist}"
  _frontend_browser_wrapper="${_ACG_STATE_DIR}/bin/frontend-browser-http.sh"
  _frontend_browser_launchctl_log="${_ACG_STATE_DIR}/logs/frontend-browser-http-launchctl.log"
  : > "${_frontend_browser_launchctl_log}"
  if ! sudo -n true 2>/dev/null && ! [[ -t 0 && -t 1 ]]; then
    _warn "[acg-down] no sudo in headless context — skipping frontend-browser-http LaunchDaemon bootout"
  else
    if _run_command --prefer-sudo --quiet --soft -- launchctl bootout system "${_frontend_browser_plist}" \
        >"${_frontend_browser_launchctl_log}" 2>&1; then
      _info "[acg-down] Frontend browser HTTP listener launchd daemon unloaded"
    fi
  fi
  _run_command --prefer-sudo --soft -- rm -f "${_frontend_browser_plist}" "${_frontend_browser_wrapper}" >/dev/null 2>&1 || true

  _info "[acg-down] Stopping Keycloak port-forward launchd agent..."
  _kc_pf_label="com.k3d-manager.keycloak-port-forward"
  _kc_pf_plist="${HOME}/Library/LaunchAgents/${_kc_pf_label}.plist"
  _kc_pf_wrapper="${_ACG_STATE_DIR}/bin/keycloak-port-forward.sh"
  if launchctl list "${_kc_pf_label}" >/dev/null 2>&1; then
    launchctl unload "${_kc_pf_plist}" 2>/dev/null || true
    _info "[acg-down] Keycloak port-forward launchd agent unloaded"
  fi
  rm -f "${_kc_pf_plist}" "${_kc_pf_wrapper}"
fi

if [[ "${_keep_hub}" -eq 0 ]]; then
  _info "[acg-down] Tearing down local Hub cluster (${_HUB_CLUSTER})..."
  if k3d cluster list 2>/dev/null | grep -q "^${_HUB_CLUSTER}[[:space:]]"; then
    k3d cluster delete "${_HUB_CLUSTER}"
    _info "[acg-down] Local Hub cluster deleted"
  else
    _info "[acg-down] Local Hub cluster not found — skipping"
  fi
else
  _info "[acg-down] --keep-hub set — local Hub cluster preserved"
fi

_info "[acg-down] Pruning Docker build cache and unused images..."
if command -v docker >/dev/null 2>&1; then
  docker system prune --force >/dev/null
  _info "[acg-down] Docker prune complete"
fi

_info "[acg-down] Cleaning up stale /tmp files..."
rm -f /tmp/argocd-*.sock
rm -f /tmp/k3d-config-tmp-*.yaml
rm -f /tmp/k3d-hostsfile-*
rm -f /tmp/k3d-manager-tunnel.out
rm -f /tmp/k3d-manager-tunnel.err
rm -f /tmp/k3d-manager-acg-watch.out
rm -f /tmp/k3d-manager-acg-watch.err
rm -f /tmp/k3dm-acg-screenshot-*.png
_info "[acg-down] /tmp cleanup complete"

if [[ "${_keep_hub}" -eq 1 ]]; then
  _info "[acg-down] Done. Remote cluster deleted; local Hub preserved."
else
  _info "[acg-down] Done. Remote cluster and local Hub deleted."
fi
