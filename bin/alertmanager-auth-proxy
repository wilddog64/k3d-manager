#!/usr/bin/env python3
"""Basic-auth reverse proxy for Alertmanager."""

from __future__ import annotations

import argparse
import base64
import http.client
import sys
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from urllib.parse import urlsplit

HOP_BY_HOP_HEADERS = {
    "connection",
    "keep-alive",
    "proxy-authenticate",
    "proxy-authorization",
    "te",
    "trailers",
    "transfer-encoding",
    "upgrade",
}


def _read_env_file(path: str) -> dict[str, str]:
    data: dict[str, str] = {}
    with open(path, encoding="utf-8") as handle:
        for raw in handle:
            line = raw.strip()
            if not line or line.startswith("#") or "=" not in line:
                continue
            key, value = line.split("=", 1)
            data[key.strip()] = value.strip()
    return data


class AlertmanagerProxyHandler(BaseHTTPRequestHandler):
    backend_url = "http://127.0.0.1:19093"
    username = ""
    password = ""

    def log_message(self, fmt: str, *args: object) -> None:  # noqa: A003
        sys.stderr.write(f"[alertmanager-auth-proxy] {fmt % args}\n")

    def _auth_ok(self) -> bool:
        header = self.headers.get("Authorization", "")
        if not header.startswith("Basic "):
            return False
        try:
            decoded = base64.b64decode(header.split(" ", 1)[1], validate=True).decode("utf-8")
        except Exception:
            return False
        return decoded == f"{self.username}:{self.password}"

    def _send_unauthorized(self) -> None:
        body = b"Authentication required\n"
        self.send_response(401)
        self.send_header("WWW-Authenticate", 'Basic realm="Alertmanager"')
        self.send_header("Content-Type", "text/plain; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        if self.command != "HEAD":
            self.wfile.write(body)

    def _proxy(self) -> None:
        parsed = urlsplit(self.backend_url)
        if parsed.scheme != "http":
            self.send_error(502, "backend must use http://")
            return

        body = b""
        content_length = self.headers.get("Content-Length")
        if content_length:
            body = self.rfile.read(int(content_length))

        conn = http.client.HTTPConnection(parsed.hostname, parsed.port or 80, timeout=30)
        try:
            headers = {
                key: value
                for key, value in self.headers.items()
                if key.lower() not in HOP_BY_HOP_HEADERS and key.lower() != "authorization"
            }
            incoming_host = self.headers.get("Host", parsed.netloc)
            headers["Host"] = incoming_host
            headers["X-Forwarded-Host"] = incoming_host
            headers["X-Forwarded-Proto"] = "https"
            path = self.path if self.path.startswith("/") else f"/{self.path}"
            conn.request(self.command, path, body=body, headers=headers)
            response = conn.getresponse()
            payload = response.read()
            self.send_response(response.status, response.reason)
            for key, value in response.getheaders():
                if key.lower() in HOP_BY_HOP_HEADERS:
                    continue
                self.send_header(key, value)
            self.send_header("Content-Length", str(len(payload)))
            self.end_headers()
            if self.command != "HEAD":
                self.wfile.write(payload)
        except Exception as exc:  # pragma: no cover - defensive proxy failure
            self.send_error(502, f"backend error: {exc}")
        finally:
            conn.close()

    def _handle(self) -> None:
        if not self._auth_ok():
            self._send_unauthorized()
            return
        self._proxy()

    do_GET = _handle
    do_HEAD = _handle
    do_POST = _handle
    do_PUT = _handle
    do_PATCH = _handle
    do_DELETE = _handle
    do_OPTIONS = _handle


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--credentials-file", required=True)
    parser.add_argument("--listen", default="127.0.0.1:9093")
    parser.add_argument("--backend", default=None)
    args = parser.parse_args()

    creds = _read_env_file(args.credentials_file)
    username = creds.get("ALERTMANAGER_BASIC_AUTH_USER", "")
    password = creds.get("ALERTMANAGER_BASIC_AUTH_PASSWORD", "")
    backend_url = args.backend or creds.get("ALERTMANAGER_BACKEND_URL", "http://127.0.0.1:19093")
    if not username or not password:
        print(
            "[alertmanager-auth-proxy] credentials file missing ALERTMANAGER_BASIC_AUTH_USER or ALERTMANAGER_BASIC_AUTH_PASSWORD",
            file=sys.stderr,
        )
        return 1

    host, port_str = args.listen.rsplit(":", 1)
    server = ThreadingHTTPServer((host, int(port_str)), AlertmanagerProxyHandler)
    server.daemon_threads = True
    AlertmanagerProxyHandler.username = username
    AlertmanagerProxyHandler.password = password
    AlertmanagerProxyHandler.backend_url = backend_url
    print(
        f"[alertmanager-auth-proxy] listening on {args.listen} -> {backend_url}",
        file=sys.stderr,
    )
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        return 0
    finally:
        server.server_close()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
