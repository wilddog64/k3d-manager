#!/usr/bin/env bash
# Bash wrapper for /ask agent invocations.
# Read-only by default; fix mode (K3DM_FIX_MODE=1) unlocks specific recovery operations.
# Blocks destructive commands and out-of-scope path access in both modes.
set -euo pipefail

K3DM_REPO="${K3DM_REPO_ROOT:-${HOME}/src/gitrepo/personal/k3d-manager}"
SHOPPING_CARTS_ROOT="${K3DM_SHOPPING_CARTS_ROOT:-${HOME}/src/gitrepo/personal/shopping-carts}"
FIX_MODE="${K3DM_FIX_MODE:-0}"

_deny() {
  echo "❌ Blocked: '$*' — operation not permitted for /ask agents." >&2
  exit 1
}

_deny_scope() {
  echo "❌ Out of scope: '$*' — agents are limited to k3d-manager and shopping-cart repos." >&2
  exit 1
}

# Reconstruct the command string for pattern matching
CMD="$*"

if [[ "$FIX_MODE" == "1" ]]; then
  # ── Fix mode: allow make fix-* targets + narrow kubectl/argocd ops ───────────
  # make fix-* targets are the preferred path; raw kubectl ops remain in the
  # allowlist because make targets call kubectl in sub-processes via this sandbox.

  # make: only fix-* targets allowed; all other make invocations are blocked
  if echo "$CMD" | grep -qE '\bmake\b'; then
    if ! echo "$CMD" | grep -qE '\bmake\b.*(fix-[a-z]|file-bug)'; then
      _deny "$CMD"
    fi
  fi

  # kubectl: allow rollout restart and delete pod only
  if echo "$CMD" | grep -qE '\bkubectl\b'; then
    if echo "$CMD" | grep -qE '\bkubectl\b.*\bdelete\b' && ! echo "$CMD" | grep -qE '\bkubectl\b.*delete\s+pod'; then
      _deny "$CMD"
    fi
    if echo "$CMD" | grep -qE '\bkubectl\b.*(apply|create|edit|patch|replace|scale|cordon|drain|taint|label|annotate|expose|run\b|cp\b|exec\b|port-forward)'; then
      _deny "$CMD"
    fi
  fi

  # argocd: allow app sync only
  if echo "$CMD" | grep -qE '\bargocd\b'; then
    if ! echo "$CMD" | grep -qE '\bargocd\b.*app\s+sync'; then
      _deny "$CMD"
    fi
  fi

  # helm: still fully blocked in fix mode (too broad)
  if echo "$CMD" | grep -qE '\bhelm\b.*(install|uninstall|upgrade|rollback|delete|push|repo add|repo remove)'; then
    _deny "$CMD"
  fi

else
  # ── Read-only mode (default) ─────────────────────────────────────────────────

  # kubectl write operations
  if echo "$CMD" | grep -qE '\bkubectl\b.*(delete|apply|create|edit|patch|replace|rollout restart|scale|cordon|drain|taint|label|annotate|expose|run\b|cp\b|exec\b|port-forward|auth can-i --list)'; then
    _deny "$CMD"
  fi

  # argocd write operations
  if echo "$CMD" | grep -qE '\bargocd\b.*(app (sync|delete|create|update|set|patch)|repo (add|rm)|cluster (add|rm)|proj (create|delete))'; then
    _deny "$CMD"
  fi

  # helm write operations
  if echo "$CMD" | grep -qE '\bhelm\b.*(install|uninstall|upgrade|rollback|delete|push|repo add|repo remove)'; then
    _deny "$CMD"
  fi

fi

# ── Always blocked (both modes) ───────────────────────────────────────────────

# Destructive filesystem / process commands
if echo "$CMD" | grep -qE '\b(rm|rmdir|dd|mkfs|shred|truncate|mv|chmod|chown|kill|killall|pkill)\b'; then
  _deny "$CMD"
fi

# curl/wget write operations
if echo "$CMD" | grep -qE '\b(curl|wget)\b.*(-X\s*(POST|PUT|DELETE|PATCH)|--request\s*(POST|PUT|DELETE|PATCH)|--data|--upload-file)'; then
  _deny "$CMD"
fi

# Destructive git operations
if echo "$CMD" | grep -qE '\bgit\b.*(reset\s+--hard|clean\s+-f|push\s+--force|push\s+-f|branch\s+-[Dd]|rebase|cherry-pick|stash\s+drop|reflog\s+delete)'; then
  _deny "$CMD"
fi

# Block file access outside allowed repos (absolute path arguments only)
for arg in "$@"; do
  if [[ "$arg" == /* ]]; then
    real_arg="$(realpath -m "$arg" 2>/dev/null || echo "$arg")"
    if [[ "$real_arg" != "${K3DM_REPO}"* && "$real_arg" != "${SHOPPING_CARTS_ROOT}"* \
       && "$real_arg" != /tmp/* && "$real_arg" != /var/tmp/* \
       && "$real_arg" != /proc/* && "$real_arg" != /sys/* ]]; then
      _deny_scope "$arg"
    fi
  fi
done

exec /bin/bash "$@"
