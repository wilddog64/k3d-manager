deploy_shopping_cart_data

_info "[acg-up] Step 10c/14 — Deploying identity stack (Keycloak + LDAP) via ArgoCD..."
# Force ArgoCD to pick up the identity Application from shopping-cart-infra
kubectl apply --context k3d-k3d-cluster -f - <<'IDEOF'
apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: shopping-cart-identity
  namespace: cicd
  annotations:
    argocd.argoproj.io/sync-wave: "-1"
  finalizers:
    - resources-finalizer.argocd.argoproj.io
spec:
  project: platform
  sources:
    - repoURL: https://github.com/wilddog64/shopping-cart-infra.git
      targetRevision: HEAD
      path: identity/keycloak
    - repoURL: https://github.com/wilddog64/shopping-cart-infra.git
      targetRevision: HEAD
      path: identity/ldap
  destination:
    server: https://kubernetes.default.svc
    namespace: identity
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=true
    retry:
      limit: 5
      backoff:
        duration: 10s
        factor: 2
        maxDuration: 3m
IDEOF

_info "[acg-up] Waiting for Keycloak API to be Ready (up to 5 min)..."
_kc_pf_port=18080
_kc_ready=false
# Start a temporary port-forward for the health check
kubectl port-forward svc/keycloak -n identity --context k3d-k3d-cluster "${_kc_pf_port}:80" \
  >>"${HOME}/.local/share/k3d-manager/keycloak-readiness-pf.log" 2>&1 &
_kc_readiness_pf_pid=$!

for i in $(seq 1 30); do
  if curl -sf "http://localhost:${_kc_pf_port}/health/ready" >/dev/null 2>&1; then
    _kc_ready=true
    break
  fi
  _info "[acg-up] Keycloak API not ready yet (attempt ${i}/30) — waiting 10s..."
  sleep 10
done

kill "${_kc_readiness_pf_pid}" 2>/dev/null || true

if [[ "${_kc_ready}" != "true" ]]; then
  _info "[acg-up] WARNING: Keycloak API not Ready after 5 min — skipping realm import. Run manually: bin/acg-up --import-realm"
else
  _info "[acg-up] Step 10d/14 — Importing Keycloak realm shopping-cart..."
  # Re-establish port-forward for actual import
  kubectl port-forward svc/keycloak -n identity --context k3d-k3d-cluster "${_kc_pf_port}:80" \
    >>"${HOME}/.local/share/k3d-manager/keycloak-pf.log" 2>&1 &
  _kc_pf_pid=$!
  disown "${_kc_pf_pid}"
  sleep 3

  _kc_token=$(curl -sf -X POST \
    "http://localhost:${_kc_pf_port}/realms/master/protocol/openid-connect/token" \
    -d "client_id=admin-cli&grant_type=password&username=admin&password=${_kc_admin_pass}" \
    | grep -o '"access_token":"[^"]*"' | sed 's/"access_token":"//;s/"//') || _kc_token=""

  if [[ -z "${_kc_token}" ]]; then
    _info "[acg-up] WARNING: Could not get Keycloak admin token — skipping realm import"
    kill "${_kc_pf_pid}" 2>/dev/null || true
  else
    _realm_json=$(sed \
      -e "s/\${ARGOCD_CLIENT_SECRET}/${_argocd_client_secret}/g" \
      -e "s/\${ORDER_SERVICE_CLIENT_SECRET}/${_order_client_secret}/g" \
      -e "s/\${PRODUCT_CATALOG_CLIENT_SECRET}/${_product_client_secret}/g" \
      -e "s/\${GRAFANA_CLIENT_SECRET}/${_grafana_client_secret}/g" \
      -e "s/\${LDAP_BIND_CREDENTIAL}/${_ldap_admin_pass}/g" \
      "${REPO_ROOT}/../shopping-carts/shopping-cart-infra/identity/config/realm-shopping-cart.json")
    _realm_json_file="$(mktemp -t keycloak-realm.XXXXXX.json)"
    printf '%s\n' "${_realm_json}" > "${_realm_json_file}"

    _import_status=$(curl -sf -o /dev/null -w "%{http_code}" \
      -X POST \
      -H "Authorization: Bearer ${_kc_token}" \
      -H "Content-Type: application/json" \
      --data-binary @"${_realm_json_file}" \
      "http://localhost:${_kc_pf_port}/admin/realms" 2>/dev/null || echo "000")

    if [[ "${_import_status}" == "201" ]]; then
      _info "[acg-up] Keycloak realm 'shopping-cart' imported successfully"
    elif [[ "${_import_status}" == "409" ]]; then
      _info "[acg-up] Keycloak realm 'shopping-cart' already exists — reconciling client config"
    else
      _info "[acg-up] WARNING: Realm import returned HTTP ${_import_status} — check Keycloak logs"
    fi

    if _keycloak_reconcile_realm_client "http://localhost:${_kc_pf_port}" "${_kc_token}" "shopping-cart" "argocd" "${_realm_json_file}"; then
      _info "[acg-up] Keycloak client 'argocd' reconciled from realm JSON"
    else
      _warn "[acg-up] Could not reconcile Keycloak client 'argocd' — check Keycloak logs"
    fi

    kill "${_kc_pf_pid}" 2>/dev/null || true
    rm -f "${_realm_json_file}"
  fi
fi

if _is_mac; then
  _info "[acg-up] Step 10e/14 — Installing Keycloak browser HTTP listener (keycloak.shopping-cart.local:80, auto-restart)..."
  _keycloak_browser_label="com.k3d-manager.keycloak-browser-http"
  _keycloak_browser_plist="${HOME}/Library/LaunchDaemons/${_keycloak_browser_label}.plist"
  _keycloak_browser_log="${HOME}/.local/share/k3d-manager/keycloak-browser-http.log"
  _keycloak_browser_launchctl_log="${HOME}/.local/share/k3d-manager/keycloak-browser-http-launchctl.log"
  _keycloak_browser_wrapper="${HOME}/.local/share/k3d-manager/keycloak-browser-http.sh"
  _keycloak_browser_plist_tmp="${HOME}/.local/share/k3d-manager/keycloak-browser-http.plist"
  _keycloak_browser_kubeconfig="${HOME}/.kube/config"
  mkdir -p "$(dirname "${_keycloak_browser_log}")"
  if curl -sf --max-time 1 http://127.0.0.1/health/ready >/dev/null 2>&1; then
    _info "[acg-up] Keycloak browser HTTP listener already healthy at http://keycloak.shopping-cart.local — skipping launchd reinstall"
  else
    _argocd_write_port_forward_wrapper "${_keycloak_browser_wrapper}" "${_keycloak_browser_log}" "$(command -v kubectl)" "$(command -v curl)" "identity" "k3d-k3d-cluster" "svc/keycloak" "80" "80" "http://127.0.0.1/health/ready" "${_keycloak_browser_kubeconfig}"
    cat > "${_keycloak_browser_plist_tmp}" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>${_keycloak_browser_label}</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>${_keycloak_browser_wrapper}</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>${_keycloak_browser_log}</string>
  <key>StandardErrorPath</key>
  <string>${_keycloak_browser_log}</string>
</dict>
</plist>
PLIST
    : > "${_keycloak_browser_launchctl_log}"
    if _run_command --interactive-sudo --quiet --soft -- launchctl bootout system "${_keycloak_browser_plist}" \
        >"${_keycloak_browser_launchctl_log}" 2>&1; then
      _info "[acg-up] Stopped existing Keycloak browser HTTP listener"
    elif [[ -s "${_keycloak_browser_launchctl_log}" ]]; then
      tail -n 20 "${_keycloak_browser_launchctl_log}" >&2 || true
      _warn "[acg-up] existing Keycloak browser HTTP listener was not loaded; continuing"
    fi
    : > "${_keycloak_browser_launchctl_log}"
    if ! _run_command --interactive-sudo --quiet -- install -m 644 "${_keycloak_browser_plist_tmp}" "${_keycloak_browser_plist}" \
        >"${_keycloak_browser_launchctl_log}" 2>&1; then
      if [[ -s "${_keycloak_browser_launchctl_log}" ]]; then
        tail -n 20 "${_keycloak_browser_launchctl_log}" >&2 || true
      fi
      _err "[acg-up] failed to install Keycloak browser HTTP listener plist; see ${_keycloak_browser_launchctl_log}"
    fi
    rm -f "${_keycloak_browser_plist_tmp}"
    : > "${_keycloak_browser_launchctl_log}"
    if ! _run_command --interactive-sudo --quiet -- launchctl bootstrap system "${_keycloak_browser_plist}" \
        >"${_keycloak_browser_launchctl_log}" 2>&1; then
      if [[ -s "${_keycloak_browser_launchctl_log}" ]]; then
        tail -n 20 "${_keycloak_browser_launchctl_log}" >&2 || true
      fi
      _err "[acg-up] failed to bootstrap Keycloak browser HTTP listener; see ${_keycloak_browser_launchctl_log}"
    fi
    _info "[acg-up] Keycloak browser HTTP listener reachable at http://keycloak.shopping-cart.local (launchd: ${_keycloak_browser_label})"
  fi
fi

_info "[acg-up] Step 10f/14 — Wiring ArgoCD SSO (Keycloak VirtualService + argocd-cm + secret patch)..."

# Apply Keycloak VirtualService so in-cluster pods reach keycloak.shopping-cart.local via Istio
KEYCLOAK_VIRTUALSERVICE_HOST=keycloak.shopping-cart.local \
KEYCLOAK_VIRTUALSERVICE_GATEWAY=istio-system/default-gateway \
KEYCLOAK_NAMESPACE=identity \
KEYCLOAK_SERVICE_PORT=80 \
  envsubst < "${REPO_ROOT}/scripts/etc/keycloak/virtualservice.yaml.tmpl" | \
  kubectl apply --context k3d-k3d-cluster -f -

# Patch CoreDNS Corefile to rewrite keycloak.shopping-cart.local → keycloak.identity.svc.cluster.local.
# Using 'rewrite' plugin because 'hosts' can only be used once per server block (conflicts with NodeHosts).
_current_corefile=$(kubectl get cm coredns -n kube-system --context k3d-k3d-cluster \
  -o jsonpath='{.data.Corefile}')
if ! printf '%s' "${_current_corefile}" | grep -qF 'keycloak.shopping-cart.local'; then
  _new_corefile=$(python3 - "${_current_corefile}" <<'PYEOF'
import sys, re
text = sys.argv[1]
rewrite_rule = "    rewrite name keycloak.shopping-cart.local keycloak.identity.svc.cluster.local\n"
# Remove any previous attempt (idempotent re-runs)
text = re.sub(r'    rewrite name keycloak\.shopping-cart\.local .*\n', '', text)
# Insert before 'kubernetes cluster.local'
text = text.replace('    kubernetes cluster.local', rewrite_rule + '    kubernetes cluster.local')
print(text, end='')
PYEOF
)
  kubectl patch cm coredns -n kube-system --context k3d-k3d-cluster \
    --type merge \
    --patch "$(python3 -c "import json,sys; print(json.dumps({'data':{'Corefile':sys.argv[1]}}))" "${_new_corefile}")"
  kubectl rollout restart deployment/coredns -n kube-system --context k3d-k3d-cluster
  kubectl rollout status deployment/coredns -n kube-system --context k3d-k3d-cluster --timeout=60s
  _info "[acg-up] CoreDNS Corefile patched (rewrite): keycloak.shopping-cart.local → keycloak.identity.svc.cluster.local"
fi

# Apply argocd-cm and argocd-rbac-cm from shopping-cart-infra (now using namespace: cicd)
_infra_root="${REPO_ROOT}/../shopping-carts/shopping-cart-infra"
kubectl apply --context k3d-k3d-cluster \
  -f "${_infra_root}/argocd/config/argocd-cm.yaml" \
  -f "${_infra_root}/argocd/config/argocd-rbac-cm.yaml"

# Patch argocd-secret directly with the OIDC client secret generated earlier in this run.
# The ExternalSecret (argocd-oidc-secret) will take over once ClusterSecretStore is Ready;
# this immediate patch ensures ArgoCD SSO works on first boot before ESO syncs.
kubectl patch secret argocd-secret -n cicd --context k3d-k3d-cluster \
  --type merge \
  --patch "{\"stringData\":{\"oidc.keycloak.clientSecret\":\"${_argocd_client_secret}\"}}"
# Add /etc/hosts entries on the Mac host for local browser access
_argocd_host_ip="127.0.0.1"
_kc_browser_ip="127.0.0.1"
_HOSTS_LIST=(
  "argocd.shopping-cart.local|${_argocd_host_ip}"
  "keycloak.shopping-cart.local|${_kc_browser_ip}"
)
for _host_ip_pair in "${_HOSTS_LIST[@]}"; do
  _h="${_host_ip_pair%%|*}"
  _desired_ip="${_host_ip_pair#*|}"
  if [[ -z "${_desired_ip}" ]]; then
    _warn "[acg-up] could not determine the ingressgateway IP for ${_h} — browser login may fail"
    continue
  fi
  _desired_host_entry="${_desired_ip} ${_h}"
  _current_host_entry=$(grep -E "^[0-9.]+[[:space:]]+${_h//./\\.}$" /etc/hosts | tail -n 1 || true)
  if [[ "${_current_host_entry}" != "${_desired_host_entry}" ]]; then
    _info "[acg-up] Updating /etc/hosts for ${_h} → ${_desired_ip} (requires sudo)..."
    if _run_command --prefer-sudo --soft -- \
        sh -c "set -e
tmp=\$(mktemp)
grep -vE '^[0-9.]+[[:space:]]+${_h//./\\.}$' /etc/hosts > \"\$tmp\"
printf '%s\n' '${_desired_host_entry}' >> \"\$tmp\"
cat \"\$tmp\" > /etc/hosts
rm -f \"\$tmp\""; then
      _info "[acg-up] /etc/hosts: ${_h} → ${_desired_ip}"
    else
      _warn "could not update /etc/hosts for ${_h} — please add manually: ${_desired_host_entry}"
    fi
  fi
done

# Restart argocd-server to pick up the updated argocd-cm and argocd-secret
kubectl rollout restart deployment/argocd-server -n cicd --context k3d-k3d-cluster
kubectl rollout status deployment/argocd-server -n cicd --context k3d-k3d-cluster --timeout=120s
_info "[acg-up] ArgoCD SSO wired: login at https://argocd.shopping-cart.local → Keycloak realm shopping-cart"

