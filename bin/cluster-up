if _is_mac; then
  _info "[acg-up] Step 10h/14 — Installing Cloudflare named tunnel (argocd + frontend + keycloak + prometheus + grafana)..."
  _tunnel_dir="${_ACG_STATE_DIR}"
  _tunnel_urls_file="${_tunnel_dir}/tunnel-urls.txt"
  _cloudflared_config="${HOME}/.cloudflared/config.yml"
  _cf_static_config="${REPO_ROOT}/scripts/etc/cloudflared/config.yml"
  _cf_tunnel_creds_id="bb7ece59-8680-4310-9437-232f862e2773"
  _cf_tunnel_creds_file="${HOME}/.cloudflared/${_cf_tunnel_creds_id}.json"
  mkdir -p "${_tunnel_dir}/logs" "${_tunnel_dir}/run" "${HOME}/.cloudflared"

  if ! command -v cloudflared >/dev/null 2>&1; then
    if command -v brew >/dev/null 2>&1; then
      _info "[acg-up] Installing cloudflared via Homebrew..."
      brew install cloudflared >/dev/null 2>&1 || _warn "[acg-up] cloudflared install failed — skipping tunnel"
    else
      _warn "[acg-up] cloudflared not found and brew unavailable — skipping tunnel"
    fi
  fi

  if command -v cloudflared >/dev/null 2>&1; then
    if [[ ! -f "${_cf_tunnel_creds_file}" ]]; then
      _info "[acg-up] Restoring cloudflared credentials from Keychain..."
      _kc_creds=$(security find-generic-password -a cloudflared \
        -s k3d-manager-cloudflared-credentials -w 2>/dev/null || true)
      if [[ -n "${_kc_creds}" ]]; then
        printf '%s' "${_kc_creds}" > "${_cf_tunnel_creds_file}"
        _info "[acg-up] Cloudflare tunnel credentials restored from Keychain"
      else
        _warn "[acg-up] No cloudflared credentials in Keychain — tunnel may not authenticate (run: cloudflared tunnel login)"
      fi
    fi
    if [[ ! -f "${HOME}/.cloudflared/cert.pem" ]]; then
      _kc_cert=$(security find-generic-password -a cloudflared \
        -s k3d-manager-cloudflared-cert -w 2>/dev/null || true)
      if [[ -n "${_kc_cert}" ]]; then
        printf '%s' "${_kc_cert}" > "${HOME}/.cloudflared/cert.pem"
        _info "[acg-up] Cloudflare cert.pem restored from Keychain"
      fi
    fi
    if [[ -f "${_cf_static_config}" ]]; then
      cp "${_cf_static_config}" "${_cloudflared_config}"
      _info "[acg-up] Cloudflare config installed from repo (prometheus + grafana + argocd + frontend + keycloak)"
    else
      _warn "[acg-up] ${_cf_static_config} not found — skipping config install"
    fi
  fi

  if command -v cloudflared >/dev/null 2>&1 && [[ -f "${_cloudflared_config}" ]]; then
    _named_tunnel_label="com.k3d-manager.cloudflare-tunnel"
    _named_tunnel_log="${_tunnel_dir}/logs/cloudflare-tunnel.log"
    _named_tunnel_plist="${HOME}/Library/LaunchAgents/${_named_tunnel_label}.plist"
    _named_tunnel_plist_tmp="${_tunnel_dir}/run/cloudflare-tunnel.plist"
    _cloudflared_bin="$(command -v cloudflared)"

    cat > "${_named_tunnel_plist_tmp}" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>${_named_tunnel_label}</string>
  <key>ProgramArguments</key>
  <array>
    <string>${_cloudflared_bin}</string>
    <string>tunnel</string>
    <string>--config</string>
    <string>${_cloudflared_config}</string>
    <string>run</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>${_named_tunnel_log}</string>
  <key>StandardErrorPath</key>
  <string>${_named_tunnel_log}</string>
</dict>
</plist>
PLIST

    _tunnel_launchctl_log="${_tunnel_dir}/logs/cloudflare-tunnel-launchctl.log"
    : > "${_tunnel_urls_file}"
    if [[ -f "${_named_tunnel_plist}" ]] && diff -q "${_named_tunnel_plist_tmp}" "${_named_tunnel_plist}" >/dev/null 2>&1; then
      rm -f "${_named_tunnel_plist_tmp}"
      _info "[acg-up] Cloudflare named tunnel LaunchAgent unchanged — skipping reinstall"
    else
      : > "${_tunnel_launchctl_log}"
      launchctl bootout "gui/$(id -u)" "${_named_tunnel_plist}" \
        >"${_tunnel_launchctl_log}" 2>&1 || true
      _named_tunnel_plist_legacy="/Library/LaunchDaemons/${_named_tunnel_label}.plist"
      if [[ -f "${_named_tunnel_plist_legacy}" ]]; then
        _run_command --interactive-sudo --quiet --soft -- launchctl bootout system "${_named_tunnel_plist_legacy}" \
          >/dev/null 2>&1 || true
        _run_command --prefer-sudo --quiet --soft -- rm -f "${_named_tunnel_plist_legacy}" \
          >/dev/null 2>&1 || true
      fi
      : > "${_tunnel_launchctl_log}"
      mkdir -p "${HOME}/Library/LaunchAgents"
      if ! install -m 644 "${_named_tunnel_plist_tmp}" "${_named_tunnel_plist}" \
          >"${_tunnel_launchctl_log}" 2>&1; then
        _warn "[acg-up] failed to install tunnel plist — skipping"
      else
        rm -f "${_named_tunnel_plist_tmp}"
        : > "${_tunnel_launchctl_log}"
        if ! launchctl bootstrap "gui/$(id -u)" "${_named_tunnel_plist}" \
            >"${_tunnel_launchctl_log}" 2>&1; then
          _warn "[acg-up] failed to bootstrap cloudflare tunnel"
        fi
      fi
    fi
    _argocd_url="${ARGOCD_PUBLIC_URL:-https://argocd.${CF_DOMAIN:-3ai-talk.org}}"
    _frontend_url="${FRONTEND_PUBLIC_URL:-https://frontend.${CF_DOMAIN:-3ai-talk.org}}"
    _keycloak_public_url="${KEYCLOAK_PUBLIC_URL:-https://keycloak.${CF_DOMAIN:-3ai-talk.org}}"
    {
      printf 'argocd=%s\n' "${_argocd_url}"
      printf 'frontend=%s\n' "${_frontend_url}"
      printf 'keycloak=%s\n' "${_keycloak_public_url}"
    } > "${_tunnel_urls_file}"
    _info "[acg-up] Cloudflare tunnel URLs written to ${_tunnel_urls_file}"
    _info "[acg-up] ArgoCD public URL:   ${_argocd_url}"
    _info "[acg-up] Frontend public URL: ${_frontend_url}"
    _info "[acg-up] Keycloak public URL: ${_keycloak_public_url}"
  elif [[ ! -f "${_cloudflared_config}" ]]; then
    _warn "[acg-up] ~/.cloudflared/config.yml not found — skipping named tunnel (run: cloudflared tunnel login && cloudflared tunnel create k3d-manager)"
  fi
fi

_info "[acg-up] Step 11/14 — Verifying ClusterSecretStore..."
_css_ready=false
for i in $(seq 1 18); do
  _css_status=$(kubectl get clustersecretstore vault-backend --context ubuntu-k3s \
    -o jsonpath='{.status.conditions[?(@.type=="Ready")].status}' 2>/dev/null || echo "")
  if [[ "${_css_status}" == "True" ]]; then
    _css_ready=true
    break
  fi
  _info "[acg-up] ClusterSecretStore not Ready yet (attempt ${i}/18) — waiting 10s..."
  sleep 10
done
if [[ "${_css_ready}" == "true" ]]; then
  _info "[acg-up] ClusterSecretStore vault-backend: Ready"
else
  _info "[acg-up] ClusterSecretStore not Ready after 180s — check vault-bridge connectivity"
fi

shopping_cart_reconcile_order_service
shopping_cart_reconcile_product_catalog

