  _argocd_write_port_forward_wrapper "${_kc_pf_wrapper}" "${_kc_pf_log}" "$(command -v kubectl)" "$(command -v curl)" "identity" "k3d-k3d-cluster" "svc/keycloak" "8880" "80" "http://localhost:8880/health/live"
  cat > "${_kc_pf_plist}" <<PLIST
