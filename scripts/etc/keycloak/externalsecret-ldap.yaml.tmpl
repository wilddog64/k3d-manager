apiVersion: ${KEYCLOAK_ESO_API_VERSION}
kind: ExternalSecret
metadata:
  name: ${KEYCLOAK_LDAP_SECRET_NAME}
  namespace: ${KEYCLOAK_NAMESPACE}
spec:
  refreshInterval: 1h
  secretStoreRef:
    kind: SecretStore
    name: ${KEYCLOAK_ESO_SECRETSTORE}
  target:
    name: ${KEYCLOAK_LDAP_SECRET_NAME}
    creationPolicy: Owner
  data:
    - secretKey: ${KEYCLOAK_LDAP_BINDDN_KEY}
      remoteRef:
        key: ${KEYCLOAK_LDAP_VAULT_PATH}
        property: ${KEYCLOAK_LDAP_BINDDN_KEY}
    - secretKey: ${KEYCLOAK_LDAP_PASSWORD_KEY}
      remoteRef:
        key: ${KEYCLOAK_LDAP_VAULT_PATH}
        property: ${KEYCLOAK_LDAP_PASSWORD_KEY}
