apiVersion: cert-manager.io/v1
kind: ClusterIssuer
metadata:
  name: ${CERT_MANAGER_PRODUCTION_ISSUER}
spec:
  acme:
    server: ${ACME_PRODUCTION_SERVER}
    email: ${ACME_EMAIL}
    privateKeySecretRef:
      name: letsencrypt-production-account-key
    solvers:
      - http01:
          ingress:
            ingressClassName: ${ACME_INGRESS_CLASS}
