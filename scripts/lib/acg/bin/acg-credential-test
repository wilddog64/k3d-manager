#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

if ! curl -sf http://localhost:9222/json >/dev/null 2>&1; then
  printf 'ERROR: Chrome CDP not running on port 9222\n' >&2
  printf 'Start with: open -a "Google Chrome" --args --remote-debugging-port=9222\n' >&2
  exit 1
fi

sandbox_url="${1:?Usage: $0 <sandbox-url> [--provider aws|gcp] [--force-restart]}"
shift

# Strip --force-restart from passthrough args; it is not understood by Node scripts
_force_restart=false
_passthrough=()
for _arg in "$@"; do
  if [[ "$_arg" == "--force-restart" ]]; then
    _force_restart=true
  else
    _passthrough+=("$_arg")
  fi
done
set -- "${_passthrough[@]+"${_passthrough[@]}"}"

_tmpout=$(mktemp)
trap 'rm -f "$_tmpout"' EXIT

_write_aws_credentials() {
  local key_id secret token
  key_id=$(grep '^AWS_ACCESS_KEY_ID=' "$_tmpout" | cut -d= -f2-)
  secret=$(grep '^AWS_SECRET_ACCESS_KEY=' "$_tmpout" | cut -d= -f2-)
  token=$(grep '^AWS_SESSION_TOKEN=' "$_tmpout" | cut -d= -f2- || true)
  mkdir -p "${HOME}/.aws"
  {
    printf '[default]\n'
    printf 'aws_access_key_id=%s\n' "$key_id"
    printf 'aws_secret_access_key=%s\n' "$secret"
    [[ -n "$token" ]] && printf 'aws_session_token=%s\n' "$token"
  } > "${HOME}/.aws/credentials"
  printf 'INFO: AWS credentials written to ~/.aws/credentials [default]\n' >&2
}

_cdp_alive() {
  curl -sf http://localhost:9222/json >/dev/null 2>&1
}

_wait_cdp_ready() {
  local _i=0
  printf 'INFO: Waiting for CDP to be ready after restart...\n' >&2
  until _cdp_alive; do
    _i=$(( _i + 1 ))
    if (( _i > 20 )); then
      printf 'ERROR: CDP not ready after 20s — Chrome may have crashed.\n' >&2
      return 1
    fi
    sleep 1
  done
  printf 'INFO: CDP ready.\n' >&2
}

_do_restart() {
  printf 'INFO: Deleting and restarting sandbox to recover fresh credentials...\n' >&2
  if _cdp_alive; then
    printf 'INFO: CDP Chrome still running on port 9222.\n' >&2
  else
    printf 'WARN: CDP Chrome is no longer running on port 9222 — acg_restart.js will use persistent context.\n' >&2
  fi
  node "$REPO_ROOT/playwright/acg_restart.js" "$sandbox_url" "$@" >&2 || {
    printf 'ERROR: Sandbox restart failed — delete it manually and re-run.\n' >&2
    exit 1
  }
}

_extract_credentials() {
  node "$REPO_ROOT/playwright/acg_credentials.js" "$sandbox_url" "$@" > "$_tmpout"
}

_print_masked() {
  sed 's/=.*/=***/' "$_tmpout" >&2
}

_azure_discover_tenant() {
  local tenant az_username domain oidc_url
  tenant=$(grep '^AZURE_TENANT_ID=' "$_tmpout" | cut -d= -f2-)
  az_username=$(grep '^AZURE_USERNAME=' "$_tmpout" | cut -d= -f2-)

  if [[ -z "$tenant" && -n "$az_username" ]]; then
    domain="${az_username#*@}"
    oidc_url="https://login.microsoftonline.com/${domain}/.well-known/openid-configuration"
    printf 'INFO: AZURE_TENANT_ID not in UI — discovering via OIDC endpoint for %s...\n' "$domain" >&2
    tenant=$(curl -sf "$oidc_url" 2>/dev/null \
      | python3 -c "import sys,json; ep=json.load(sys.stdin).get('token_endpoint',''); print(ep.split('/')[3] if ep else '')" 2>/dev/null || true)
    if [[ -n "$tenant" ]]; then
      printf 'INFO: Discovered tenant: ***\n' >&2
      printf 'AZURE_TENANT_ID=%s\n' "$tenant" >> "$_tmpout"
    else
      printf 'WARN: OIDC discovery failed for domain %s\n' "$domain" >&2
    fi
  fi

  printf '%s' "$tenant"
}

_sts_valid() {
  grep -q '^AWS_ACCESS_KEY_ID=' "$_tmpout" &&
    AWS_CONFIG_FILE=/dev/null aws sts get-caller-identity >/dev/null 2>&1
}

_az_portal_valid() {
  local username password tenant sub_id _az_err
  username=$(grep '^AZURE_USERNAME=' "$_tmpout" | cut -d= -f2-)
  password=$(grep '^AZURE_PASSWORD=' "$_tmpout" | cut -d= -f2-)
  tenant=$(_azure_discover_tenant)
  [[ -n "$username" && -n "$password" ]] || return 1

  [[ -n "$tenant" ]] || { printf 'ERROR: Could not determine Azure tenant ID\n' >&2; return 1; }

  _az_err=$(az login --username "$username" \
    --password "$password" \
    --tenant "$tenant" \
    --allow-no-subscriptions \
    --output none 2>&1) || {
    printf '%s\n' "$_az_err" | grep -v '^$' | sed 's/^/[az] /' >&2
    return 1
  }

  if ! grep -q '^AZURE_SUBSCRIPTION_ID=' "$_tmpout"; then
    sub_id=$(az account show --query id -o tsv 2>/dev/null || true)
    if [[ -n "$sub_id" ]]; then
      printf 'INFO: Discovered subscription: ***\n' >&2
      printf 'AZURE_SUBSCRIPTION_ID=%s\n' "$sub_id" >> "$_tmpout"
    fi
  fi
}

_az_sp_valid() {
  local client_id tenant secret sub_id
  client_id=$(grep '^AZURE_CLIENT_ID=' "$_tmpout" | cut -d= -f2-)
  tenant=$(_azure_discover_tenant)
  secret=$(grep '^AZURE_CLIENT_SECRET=' "$_tmpout" | cut -d= -f2-)
  [[ -n "$client_id" && -n "$secret" ]] || return 1

  [[ -n "$tenant" ]] || { printf 'ERROR: Could not determine Azure tenant ID\n' >&2; return 1; }

  local _az_err
  _az_err=$(az login --service-principal \
    -u "$client_id" \
    -p "$secret" \
    --tenant "$tenant" \
    --allow-no-subscriptions \
    --output none 2>&1) || {
    printf '%s\n' "$_az_err" | grep -v '^$' | sed 's/^/[az] /' >&2
    return 1
  }

  # Discover subscription ID now that SP is authenticated
  if ! grep -q '^AZURE_SUBSCRIPTION_ID=' "$_tmpout"; then
    sub_id=$(az account show --query id -o tsv 2>/dev/null || true)
    if [[ -n "$sub_id" ]]; then
      printf 'INFO: Discovered subscription: ***\n' >&2
      printf 'AZURE_SUBSCRIPTION_ID=%s\n' "$sub_id" >> "$_tmpout"
    fi
  fi
}

# Step 1: extract credentials (restart once if extraction itself fails)
if [[ "$_force_restart" == "true" ]]; then
  printf 'INFO: --force-restart: skipping initial extraction, going straight to restart path.\n' >&2
  _do_restart "$@"
  _wait_cdp_ready
  _extract_credentials "$@" || {
    printf 'ERROR: Credential extraction failed after forced restart.\n' >&2
    exit 1
  }
elif ! _extract_credentials "$@"; then
  _print_masked
  printf 'WARN: Credential extraction failed — restarting sandbox...\n' >&2
  _do_restart "$@"
  _wait_cdp_ready
  _extract_credentials "$@" || {
    printf 'ERROR: Credential extraction still failing after restart.\n' >&2
    exit 1
  }
fi
_print_masked

# Step 2: if AWS creds present, validate with sts; restart once on ghost-state failure
if grep -q '^AWS_ACCESS_KEY_ID=' "$_tmpout"; then
  _write_aws_credentials
  if ! _sts_valid; then
    printf 'WARN: sts:GetCallerIdentity failed — restarting sandbox for fresh credentials...\n' >&2
    _do_restart "$@"
    _wait_cdp_ready
    _extract_credentials "$@" || {
      printf 'ERROR: Credential extraction after restart failed.\n' >&2
      exit 1
    }
    _print_masked
    _write_aws_credentials
  fi
fi

# Final gate: credentials must pass sts before exiting 0
if grep -q '^AWS_ACCESS_KEY_ID=' "$_tmpout"; then
  if AWS_CONFIG_FILE=/dev/null aws sts get-caller-identity >/dev/null 2>&1; then
    printf 'INFO: AWS credentials validated (sts:GetCallerIdentity OK)\n' >&2
  else
    printf 'ERROR: sts:GetCallerIdentity failed — credentials invalid after all attempts.\n' >&2
    exit 1
  fi
fi

# Step 3: validate Azure creds — prefer portal username/password, then SP fallback
if grep -q '^AZURE_USERNAME=' "$_tmpout" && grep -q '^AZURE_PASSWORD=' "$_tmpout"; then
  if ! _az_portal_valid; then
    printf 'WARN: az login --username/--password failed — restarting sandbox for fresh credentials...\n' >&2
    _do_restart "$@"
    _wait_cdp_ready
    _extract_credentials "$@" || {
      printf 'ERROR: Credential extraction after restart failed.\n' >&2
      exit 1
    }
    _print_masked
  fi
  if _az_portal_valid; then
    printf 'INFO: Azure portal credentials validated (az login OK)\n' >&2
    printf 'INFO: Active account: %s\n' "$(az account show --query 'name' -o tsv 2>/dev/null || echo 'unknown')" >&2
  else
    printf 'ERROR: az login --username/--password failed — credentials invalid after all attempts.\n' >&2
    exit 1
  fi
elif grep -q '^AZURE_CLIENT_ID=' "$_tmpout"; then
  if ! _az_sp_valid; then
    printf 'WARN: az login --service-principal failed — restarting sandbox for fresh credentials...\n' >&2
    _do_restart "$@"
    _wait_cdp_ready
    _extract_credentials "$@" || {
      printf 'ERROR: Credential extraction after restart failed.\n' >&2
      exit 1
    }
    _print_masked
  fi
  if _az_sp_valid; then
    printf 'INFO: Azure SP credentials validated (az login OK)\n' >&2
    printf 'INFO: Active account: %s\n' "$(az account show --query 'name' -o tsv 2>/dev/null || echo 'unknown')" >&2
  else
    printf 'ERROR: az login --service-principal failed — credentials invalid after all attempts.\n' >&2
    exit 1
  fi
fi
